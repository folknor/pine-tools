// @test regression/INV098-forin-non-iterable
// @description `for...in` over a scalar (e.g. `close`, a series float) is not iterable: TV's CE10123 for the `foreach` pseudo-function ("series float" used but "array<type>" expected), anchored at the collection. A `for...in` over a real array stays clean. Probed 2026-06-25 via pine-lint --tv, see INV098.
// @expects parse: success
// @expects error: line=4, message=/Cannot call "foreach" with argument "id"="close"/
// @expects errors: 1

//@version=6
indicator("INV098-forin-non-iterable")
s = 0.0
for x in close
    s := s + x
arr = array.new<float>(3, 1.0)
for v in arr
    s := s + v
plot(s)
