// @test regression/INV031-undefined-variable-stragglers
// @description Three parser gaps behind the remaining undefined-variable FP clusters on TV-clean files, all TV-probed 2026-06-04 (see investigations/INV031-undefined-variable-stragglers/notes.md): (1) a tuple destructure's RHS may start on a wrapped, blank-line-separated continuation line - previously the failed parse backtracked into an ArrayExpression USE of the names; (2) a type keyword directly followed by `=` is a variable NAME (`var color color = na`, `var line line = na` are idiomatic) - previously the consume threw and shredded the enclosing block; (3) if/else in expression position (`int m = if cond` ...) is a real expression whose value is the consequent's tail - previously `if` parsed as a bare Identifier and the branches shredded the enclosing function body.
// @expects parse: success
// @expects no-errors
//@version=6
indicator("t")

// (1) tuple destructure with blank-line wrapped RHS
bands(float src, int len) =>
    basis = ta.sma(src, len)
    dev = ta.stdev(src, len)
    [basis, basis + dev, basis - dev]

[mid, upper, lower] =

     bands(close, 20)

// (2) type keywords as variable names
var color color = na
var line line = na
color := close > open ? #00ff41 : #ff1744

// (3) if-expression initializer inside a UDF body
monthClamp(int mon, bool roll = false) =>
    int m = if roll
        int normalized = mon
        ((normalized - 1) % 12) + 1
    else
        math.min(math.max(mon, 1), 12)
    m + 1

plot(mid + upper + lower, color = color)
plot(monthClamp(14, true))
