// @test regression/coverage-drawing-round2
// @description #52 coverage build-out round 2: drawing-object catalog entries in the corpus but no test fixture (census 2026-06-11) - the box/label/line na-cast functions and copy/getter/setter families, linefill + linefill.delete/set_color, chart.point.copy/from_time, polyline.new/delete. Valid usage per the catalog signatures; local and TV must both accept.
// @expects parse: success
// @expects no-errors

//@version=6
indicator("coverage drawing round2", overlay = true)

b = box.new(bar_index - 10, high, bar_index, low)
b2 = box.copy(b)
box.set_bgcolor(b2, color.new(color.blue, 80))
box.set_border_color(b2, color.gray)
box.set_border_style(b2, line.style_dashed)
box.set_border_width(b2, 2)
box.set_bottom(b2, low)
box.set_top(b2, high)
box.set_left(b2, bar_index - 5)
box.set_right(b2, bar_index)
box.set_lefttop(b2, bar_index - 5, high)
box.set_rightbottom(b2, bar_index, low)
box.set_extend(b2, extend.none)
box.set_text(b2, "box")
box.set_text_color(b2, color.white)
box.set_text_halign(b2, text.align_center)
box.set_text_valign(b2, text.align_top)
box.set_text_size(b2, size.small)
bb = box.get_bottom(b2)
bt = box.get_top(b2)
bl = box.get_left(b2)
br = box.get_right(b2)
box bNa = box(na)

lb = label.new(bar_index, high, "lbl")
lb2 = label.copy(lb)
label.set_color(lb2, color.orange)
label.set_size(lb2, size.normal)
label.set_style(lb2, label.style_label_down)
label.set_text(lb2, "copy")
label.set_textalign(lb2, text.align_left)
label.set_textcolor(lb2, color.black)
label.set_tooltip(lb2, "tip")
label.set_x(lb2, bar_index - 1)
label.set_y(lb2, high)
label.set_xy(lb2, bar_index, high)
label.set_xloc(lb2, time, xloc.bar_time)
label.set_yloc(lb2, yloc.abovebar)
lt = label.get_text(lb2)
lx = label.get_x(lb2)
ly = label.get_y(lb2)

ln = line.new(bar_index - 10, low, bar_index, high)
ln2 = line.copy(ln)
line.set_style(ln2, line.style_dotted)
line.set_extend(ln2, extend.both)
line.set_x1(ln2, bar_index - 8)
line.set_x2(ln2, bar_index)
line.set_y1(ln2, low)
line.set_y2(ln2, high)
line.set_xy1(ln2, bar_index - 8, low)
line.set_xy2(ln2, bar_index, high)
line.set_xloc(ln2, line.get_x1(ln2), line.get_x2(ln2), xloc.bar_index)
gp = line.get_price(ln2, bar_index)
gx1 = line.get_x1(ln2)
gx2 = line.get_x2(ln2)
gy1 = line.get_y1(ln2)
gy2 = line.get_y2(ln2)

pt = chart.point.from_index(bar_index, high)
pt2 = chart.point.from_time(time, low)
pt3 = chart.point.copy(pt)
line.set_first_point(ln2, pt)
line.set_second_point(ln2, pt2)

lf = linefill.new(ln, ln2, color.new(color.green, 90))
linefill.set_color(lf, color.new(color.red, 90))
linefill lfNa = linefill(na)
linefill.delete(lf)

pl = polyline.new(array.from(pt, pt2, pt3))
polyline.delete(pl)

plot(bb + bt + bl + br + lx + ly + gp + gx1 + gx2 + gy1 + gy2 + str.length(lt))
