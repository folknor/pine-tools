// @test regression/coverage-matrix-uncovered
// @description #52 coverage build-out: the 28 matrix.* catalog entries that appeared in zero fixtures (fixture-coverage census 2026-06-10) - avg/concat/det/diff/eigenvectors/is_*/kron/median/mode/pinv/pow/rank/remove_col/reshape/sort/submatrix/swap_*/trace. Void-returning ones (reshape, sort, swap_columns, swap_rows) are bare statements per INV055.
// @expects parse: success
// @expects no-errors

//@version=6
indicator("coverage matrix uncovered")
m = matrix.new<float>(2, 2, 1.0)
m2 = matrix.new<float>(2, 2, 2.0)
avg = matrix.avg(m)
cc = matrix.concat(m, m2)
dt = matrix.det(m)
df = matrix.diff(m, m2)
evec = matrix.eigenvectors(m)
b01 = matrix.is_antidiagonal(m)
b02 = matrix.is_antisymmetric(m)
b03 = matrix.is_binary(m)
b04 = matrix.is_diagonal(m)
b05 = matrix.is_identity(m)
b06 = matrix.is_square(m)
b07 = matrix.is_stochastic(m)
b08 = matrix.is_symmetric(m)
b09 = matrix.is_triangular(m)
b10 = matrix.is_zero(m)
kr = matrix.kron(m, m2)
med = matrix.median(m)
mod = matrix.mode(m)
pin = matrix.pinv(m)
pw = matrix.pow(m, 2)
rk = matrix.rank(m)
removed = matrix.remove_col(m2, 0)
matrix.reshape(m2, 1, 2)
msort = matrix.new<float>(2, 2, 3.0)
matrix.sort(msort)
sub = matrix.submatrix(m, 0, 1, 0, 1)
matrix.swap_columns(m, 0, 1)
matrix.swap_rows(m, 0, 1)
trc = matrix.trace(m)
flags = (b01 ? 1 : 0) + (b02 ? 1 : 0) + (b03 ? 1 : 0) + (b04 ? 1 : 0) + (b05 ? 1 : 0) + (b06 ? 1 : 0) + (b07 ? 1 : 0) + (b08 ? 1 : 0) + (b09 ? 1 : 0) + (b10 ? 1 : 0)
shapes = matrix.rows(cc) + matrix.rows(df) + matrix.rows(evec) + matrix.rows(kr) + matrix.rows(pin) + matrix.rows(pw) + matrix.rows(sub) + matrix.rows(msort)
plot(avg + dt + med + mod + rk + trc + flags + shapes + array.size(removed))
