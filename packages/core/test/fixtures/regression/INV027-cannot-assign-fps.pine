// @test regression/INV027-cannot-assign-fps
// @description Four FP sources behind the "Cannot assign * to *" cluster, all TV-accepted (probed 2026-06-04, see investigations/INV027-cannot-assign-fps/notes.md): (1) generic placeholder returns (matrix.transpose -> matrix<type>) resolve from the collection argument's element type; (2) request.security_lower_tf's array<type> element follows the expression argument; (3) a type annotation in a comma-separated declaration binds only to the unit it directly precedes (bool a = ..., b = input.int(...) types b int); (4) blank lines are allowed inside a wrapped ternary (the `?` continuation joins across them).
// @expects parse: success
// @expects no-errors
//@version=6
indicator("t")

// (1) placeholder return resolves from the collection arg
var matrix<bool> m  = matrix.new<bool>(2, 2, false)
var matrix<bool> mT = matrix.new<bool>(2, 2, false)
mT := matrix.transpose(m)

// (2) security_lower_tf element type follows the expression arg
sub = request.security_lower_tf(syminfo.tickerid, "1", close)
float subHi = na
if array.size(sub) > 0
    subHi := array.max(sub)

// (3) annotation binds only to its own unit
bool show_div = input.bool(false, "d"), div_len = input.int(10, "l")
int lookback = div_len

// (4) blank lines inside a wrapped ternary
color wrapColor =

     close > open

         ? color.new(color.green, 0)

     : color.new(color.red, 0)

plot(subHi)
plot(matrix.get(mT, 0, 0) ? 1 : 0)
plot(show_div ? lookback : 0, color = wrapColor)
