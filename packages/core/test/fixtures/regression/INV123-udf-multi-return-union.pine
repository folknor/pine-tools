// @test regression/INV123-udf-multi-return-union
// @description Loop 2 joins nested branch-tail UDF return leaves. Mixed bases ground to unknown; int/float widens to float. The unit test pins the inferred types.
// @expects errors: 0
//@version=6
indicator("INV123 udf multi return union")
mixed(p) =>
    if close > open
        p
    else
        1
numeric(p) =>
    if close > open
        p
    else
        1.0
a = mixed("hello")
b = numeric(1)

