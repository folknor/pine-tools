// @test regression/INV053-member-call-no-false-positive
// @description The builtin-namespace member-call check must NOT fire on: generic constructors (catalog key array.new<type>), members of an UNALIASED imported library whose name collides with a builtin namespace (import .../ta/N -> namespace ta), UDT constructors/methods, or a builtin variable called as a function (ta.tr, TV-silent). See investigations/INV053-builtin-namespace-member-calls/notes.md.
// @expects parse: success
// @expects no-errors
//@version=6
import TradingView/ta/7

type point
    float v

method dist(point this) =>
    this.v * 2

xs = array.new<float>(3, 0.0)
p = point.new(1.0)
d = p.dist()
delta = ta.requestVolumeDelta("FACE", "1")
plot(d + array.size(xs) + delta)
