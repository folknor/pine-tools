// @test regression/INV072-udt-field-validation
// @description UDT fields are indexed by declared type, so field reads flow into existing argument checks and unknown fields are rejected only when the receiver resolves to a known user type. TV-probed 2026-06-19; see investigations/INV072-udt-field-type-and-validation/notes.md.
// @expects parse: success
// @expects errors: 4
// @expects error: line=13, message=/Cannot call "str.length"/
// @expects error: line=14, message=/Object has no field nope/
// @expects error: line=15, message=/Object has no field nonexist/
// @expects error: line=17, message=/Cannot call "str.length"/
// @expects ast: body.1.type = "TypeDeclaration"
// @expects ast: body.1.name = "Inner"
// @expects ast: body.1.fields.0.name = "x"
// @expects ast: body.2.type = "TypeDeclaration"
// @expects ast: body.2.fields.0.name = "inner"
// @expects ast: body.2.fields.2.name = "type"
// @expects ast: body.3.type = "TypeDeclaration"
// @expects ast: body.3.fields.0.name = "line"
// @expects ast: body.3.fields.1.name = "label"
//@version=6
indicator("t")
type Inner
    float x
type Outer
    Inner inner
    float x
    string type
type KeywordFields
    chart.point line
    chart.point label
o = Outer.new(Inner.new(1.0), 2.0, "outer")
y = str.length(o.x)
z = o.nope
w = o.inner.nonexist
arr = array.from(1.0, 2.0, 3.0)
q = str.length(arr.first())
plot(close)
