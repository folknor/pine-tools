// @test regression/INV077-if-condition-leading-ternary-wrap
// @description If-statement conditions can continue with leading ternary and logical operators across blank lines when the continuation indent satisfies Pine's wrap rule. This shape appears in the TV-clean 6874e636 corpus fixture and previously left phantom `and`, `?`, and `:` diagnostics.
// @expects parse: success
// @expects no-errors
// @expects warnings: 0
// @expects ast: body.4.type = "IfStatement"
// @expects ast: body.4.condition.type = "BinaryExpression"
// @expects ast: body.4.condition.operator = "and"
// @expects ast: body.4.consequent.0.type = "IfStatement"
// @expects ast: body.4.consequent.0.condition.type = "TernaryExpression"
// @expects ast: body.4.consequent.0.condition.condition.name = "cond"
// @expects ast: body.4.consequent.0.condition.consequent.name = "ok"
// @expects ast: body.4.consequent.0.condition.alternate.name = "cond"
//@version=6
indicator("x")
cond = close > open
ok = high > low
result = 0.0
if cond and barstate.isconfirmed

 and (

 cond and ok

 )
    if cond

     ? ok

     : cond
        result := close
plot(result)
