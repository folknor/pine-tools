// @test regression/coverage-ta-round2
// @description #52 coverage build-out round 2: the 39 ta.* catalog entries in the corpus but no test fixture (census 2026-06-11) - moving averages (alma/hma/rma/swma/vwma/wma), oscillators (cci/cmo/cog/mfi/mom/roc/rci/stoch/tsi/wpr), stats (correlation/dev/median/mode/percentile_*/percentrank/variance), tuple returns (bb/kc), pivots (pivothigh/pivot_point_levels), running extrema (max/min/cum), event helpers (barssince/cross/falling/rising/highestbars/lowestbars), linreg and sar. Valid usage per the catalog signatures; local and TV must both accept.
// @expects parse: success
// @expects no-errors

//@version=6
indicator("coverage ta round2")

alma = ta.alma(close, 9, 0.85, 6)
bs = ta.barssince(close > open)
[bbM, bbU, bbL] = ta.bb(close, 20, 2)
cci = ta.cci(close, 20)
cmo = ta.cmo(close, 9)
cog = ta.cog(close, 10)
corr = ta.correlation(close, open, 20)
crs = ta.cross(close, open)
cum = ta.cum(volume)
dev = ta.dev(close, 20)
fall = ta.falling(close, 3)
hb = ta.highestbars(high, 10)
hma = ta.hma(close, 9)
[kcM, kcU, kcL] = ta.kc(close, 20, 2)
lreg = ta.linreg(close, 14, 0)
lb = ta.lowestbars(low, 10)
mx = ta.max(close)
mdn = ta.median(close, 10)
mfi = ta.mfi(hlc3, 14)
mn = ta.min(close)
mode = ta.mode(close, 10)
mom = ta.mom(close, 10)
pli = ta.percentile_linear_interpolation(close, 20, 50)
pnr = ta.percentile_nearest_rank(close, 20, 50)
prk = ta.percentrank(close, 20)
ppl = ta.pivot_point_levels("Traditional", timeframe.change("1D"))
ph = ta.pivothigh(high, 2, 2)
rci = ta.rci(close, 10)
ris = ta.rising(close, 3)
rma = ta.rma(close, 14)
roc = ta.roc(close, 9)
sar = ta.sar(0.02, 0.02, 0.2)
sto = ta.stoch(close, high, low, 14)
swma = ta.swma(close)
tsi = ta.tsi(close, 13, 25)
vrc = ta.variance(close, 20)
vwma = ta.vwma(close, 20)
wma = ta.wma(close, 9)
wpr = ta.wpr(14)

plot(alma + bs + bbM + bbU + bbL + cci + cmo + cog + corr + cum + dev + hb + hma + kcM + kcU + kcL)
plot(lreg + lb + mx + mdn + mfi + mn + mode + mom + pli + pnr + prk + nz(ph) + rci + rma + roc)
plot(sar + sto + swma + tsi + vrc + vwma + wma + wpr + array.size(ppl) + (crs ? 1 : 0) + (fall ? 1 : 0) + (ris ? 1 : 0))
