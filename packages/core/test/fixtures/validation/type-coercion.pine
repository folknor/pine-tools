// @test validation/type-coercion
// @description Declaration base-type rules - qualifiers free, int->float widening only; cross-type declarations are CE10173 (probed 2026-06-05, see INV032)
// @expects parse: success
// @expects errors: 7
// @expects error: line=11, message=/Cannot assign a value of the .series float. type to the .fromSeriesFloat. variable/
// @expects error: line=16, message=/Cannot assign a value of the .const int. type to the .fromInt. variable/
// @expects error: line=17, message=/Cannot assign a value of the .const float. type to the .fromFloat. variable/
// @expects error: line=20, message=/Cannot assign a value of the .const int. type to the .fromIntStr. variable/
// @expects error: line=21, message=/Cannot assign a value of the .const float. type to the .fromFloatStr. variable/
// @expects error: line=28, message=/Cannot assign a value of the .const color. type to the .colorAsInt. variable/
// @expects error: line=29, message=/Cannot assign a value of the .const color. type to the .colorAsFloat. variable/

//@version=6
indicator("Type Coercion Tests")

// Qualifier widening is free: a series initializer is fine when the BASE
// type matches (the variable just becomes series-qualified)
float simpleFloat = close  // series float -> float keyword: OK
int simpleInt = bar_index  // series int -> int keyword: OK
bool simpleBool = close > open  // series bool -> bool keyword: OK

// Cross-type narrowing is NOT allowed: float never assigns to int
int fromSeriesFloat = close  // CE10173: series float into int
float fromSeriesInt = bar_index  // OK: int widens to float

// Numeric -> color is rejected in declarations (TV CE10173; ARGB ints
// are NOT implicitly colors here)
color fromInt = 16711680
color fromFloat = 16711935.0

// Numeric -> string is rejected in declarations (no implicit tostring)
string fromIntStr = 42
string fromFloatStr = 3.14

// Array type coercion - array<type> (unresolved) to concrete array
var array<float> arr = array.new<float>()
array.push(arr, 1.0)

// Color -> numeric is rejected in declarations
int colorAsInt = color.red
float colorAsFloat = color.blue

plot(simpleFloat)
