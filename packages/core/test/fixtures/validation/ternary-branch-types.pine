// @test validation/ternary-branch-types
// @description Ternary expression branches must have compatible types. The diagnostic now uses TV's CE10123 operator form. See investigations/INV001-ternary-branch-compat/notes.md.
// @expects parse: success
// @expects errors: 3
// @expects error: line=5, message=/Cannot call "operator \?:" with argument "expr1"="123"/
// @expects error: line=8, message=/Cannot call "operator \?:" with argument "expr1"="hello"/
// @expects error: line=11, message=/Cannot call "operator \?:" with argument "expr2"="blue"/

//@version=6
indicator("Ternary Branch Type Errors")

// Error: int and color are incompatible
x = true ? 123 : color.red

// Error: string and bool are incompatible
y = true ? "hello" : false

// Error: color and string are incompatible
z = true ? color.blue : "blue"

// Valid: int and float are compatible (both numeric)
a = true ? 123 : 45.6

// Valid: same types
b = true ? "hello" : "world"

plot(close)
