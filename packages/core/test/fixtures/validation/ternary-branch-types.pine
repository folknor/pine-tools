// @test validation/ternary-branch-types
// @description Ternary expression branches must have compatible types. See investigations/INV001-ternary-branch-compat/notes.md for why we stay stricter than pine-lint here.
// @expects parse: success
// @expects errors: 3
// @expects error: line=5, message="Ternary branches must have compatible types. Got 'int' and 'color'"
// @expects error: line=8, message="Ternary branches must have compatible types. Got 'string' and 'bool'"
// @expects error: line=11, message="Ternary branches must have compatible types. Got 'color' and 'string'"

//@version=6
indicator("Ternary Branch Type Errors")

// Error: int and color are incompatible
x = true ? 123 : color.red

// Error: string and bool are incompatible
y = true ? "hello" : false

// Error: color and string are incompatible
z = true ? color.blue : "blue"

// Valid: int and float are compatible (both numeric)
a = true ? 123 : 45.6

// Valid: same types
b = true ? "hello" : "world"

plot(close)
