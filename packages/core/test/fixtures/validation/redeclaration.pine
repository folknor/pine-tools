// @test validation/redeclaration
// @description Variable redeclaration behavior
// @expects parse: success
// @expects errors: 1
// @expects error: line=11, message=/.x. is already defined/

// Same-scope redeclaration with = is TV's CE10095 (probed 2026-06-05,
// see INV035). Re-assignment needs :=.

//@version=6
indicator("Redeclaration Tests")

// First declaration
x = 10

// Redeclaration of same variable
x = 20

plot(x)
