// @test validation/logical-operators-errors
// @description Error messages for invalid logical operator operands. TV uses CE10123 operator templates for bool-context failures; see INV083.
// @expects parse: success
// @expects errors: 4
// @expects error: line=5, message=/Cannot call "operator or" with argument "expr0"="123"/
// @expects error: line=8, message=/Cannot call "operator and" with argument "expr1"="hello"/
// @expects error: line=11, message=/Cannot call "operator or" with argument "expr0"="color.red"/
// @expects error: line=14, message=/Cannot call "operator and" with argument "expr1"="3.14"/

//@version=6
indicator("Logical Operator Errors")

// Error: left operand is int, not bool
x = 123 or false

// Error: right operand is string, not bool
y = true and "hello"

// Error: left operand is color, not bool
z = color.red or true

// Error: right operand is float, not bool
w = false and 3.14

plot(close)
