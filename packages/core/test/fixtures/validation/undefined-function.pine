// @test validation/undefined-function
// @description Undefined function calls are TV's CE10271 (probed 2026-06-05, see INV036)
// @expects parse: success
// @expects errors: 1
// @expects error: line=7, message=/Could not find function or function reference .nonExistentFunction./

// An identifier callee must be a built-in or a UDF/method declared
// earlier in source.

//@version=6
indicator("Undefined Function Test")

x = nonExistentFunction(close, 14)

plot(x)
