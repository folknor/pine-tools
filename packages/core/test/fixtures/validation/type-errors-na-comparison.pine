// @test validation/type-errors-na-comparison
// @description Direct na comparison is invalid - must use na() function
// @expects parse: success
// @expects errors: 2
// @expects error: line=5, message="Cannot compare a value to 'na' directly. Use the 'na()' function instead."
// @expects error: line=6, message="Cannot compare a value to 'na' directly. Use the 'na()' function instead."

//@version=6
indicator("NA Comparison Errors")

// Direct na comparison is invalid (errors)
bool bad1 = close == na
bool bad2 = close != na

// Correct way to check for na
bool good1 = na(close)
bool good2 = not na(close)

plot(close)
