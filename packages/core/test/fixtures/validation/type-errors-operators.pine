// @test validation/type-errors-operators
// @description Type errors for operators (ternary, logical, arithmetic, comparison). Bool-context operator failures use TV's CE10123 operator template; see INV083.
// @expects parse: success
// @expects errors: 10
// @expects error: line=5, message=/Cannot call "operator \?:" with argument "expr0"="5"/
// @expects error: line=8, message=/Cannot call "operator and" with argument "expr0"="1"/
// @expects error: line=9, message=/Cannot call "operator or" with argument "expr1"="2"/
// @expects error: line=10, message=/Cannot call "operator not" with argument "expr0"="5"/
// @expects error: line=13, message="Type mismatch: cannot apply '+' to bool and int"
// @expects error: line=14, message="Type mismatch: cannot apply '-' to int and bool"
// @expects error: line=17, message="Type mismatch: cannot apply '+' to color and int"
// @expects error: line=18, message="Type mismatch: cannot apply '*' to int and color"
// @expects error: line=21, column=6, message="Type mismatch: cannot apply '>' to color and color"
// @expects error: line=21, column=18, message="Type mismatch: cannot apply '>' to color and color"

//@version=6
indicator("Operator Type Errors")

// Ternary condition must be bool (error)
x1 = 5 ? 1 : 2

// Logical operators require bool (errors)
x2 = 1 and true
x3 = true or 2
x4 = not 5

// Arithmetic on bool (errors)
x5 = true + 1
x6 = 1 - false

// Arithmetic on color (errors)
x7 = color.red + 1
x8 = 2 * color.blue

// Comparison on color (error)
x9 = color.red > color.blue

plot(close)
