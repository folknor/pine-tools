// @test syntax/tuple-after-expression
// @expects parse: success

// Test that [ at start of new line after expression is treated as tuple, not subscript
// Inits are calls - a bare tuple literal init is invalid Pine (INV049)

// After switch expression
x = switch y
    1 => a
[d, e] = 2

// After for loop
for i = 0 to 10
    x = i
[f, g] = makeTuple()

// After if statement
if condition
    result = 1
[h, j] = makeTuple()

// After variable declaration
value = 42
[m, n] = makeTuple2(value, value * 2)
