// @test syntax/newline-continuation
// @expects parse: success

// Tests for newline continuation behavior
// LBRACKET after newline should NOT be treated as array subscript
// Inits are calls - a bare tuple literal init is invalid Pine (INV049)

// Tuple after simple expression
x = 1
[a, b] = makeTuple()

// Tuple after function call
result = func()
[c, d] = makeTuple()

// Tuple after method call
value = obj.method()
[e, f] = makeTuple()

// Tuple after switch (column 0)
switch x
    1 => y
[g, h] = makeTuple()

// Tuple after for loop
for i = 0 to 5
    z = i
[j, k] = makeTuple()

// Tuple after while loop
while cond
    w = 1
[m, n] = makeTuple()

// Tuple after if statement
if test
    q = 1
[p, r] = makeTuple()

// Deeply nested tuple after switch-for
switch mode
    A =>
        for i = 0 to 3
            s = i
        [t, u] = makeTuple()
    B =>
        v = 0

// Array access on SAME line should still work
arr = myArray
elem = arr[0]

// Method chain with array access on same line
data = getData()[0]

// Operators after newline should continue expression (continuation
// lines use indent 2 - a multiple-of-4 indent is a wrap-rule error,
// see INV042)
longValue = a +
  b +
  c

// Comparison after newline
isEqual = x ==
  y

// Logical operator after newline
combined = a and
  b or
  c

// Dot access after newline. Wrapped lines must NOT be indented by a
// multiple of 4 - Pine's line-wrapping rule (po: language/script-structure
// "Line wrapping"); a multiple-of-4 indent denotes a local block. An
// indent-4 continuation here previously glued switch arms together
// (see TODO #33), so these use indent 2.
result = obj
  .method()
  .property
