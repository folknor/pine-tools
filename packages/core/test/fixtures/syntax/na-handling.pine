// @test syntax/na-handling
// @description na value handling and related functions
// @expects parse: success
// @expects errors: 1
// @expects error: line=6, message="Value with NA type cannot be assigned to a variable that was defined without type keyword"

//@version=6
indicator("NA Handling Tests")

// na literal (untyped) - an error: TV CE10097 requires a type keyword
// when the initializer is bare na (probed 2026-06-05, see INV032)
x = na

// Typed na assignments like `float y = na` are fine (na assigns to any
// type keyword except bool - see validation/na-coercion.pine)

// na comparison
isNa1 = na(close)
isNa2 = na(x)

// nz - replace na with zero or default
val1 = nz(close)
val2 = nz(close, 0)
val3 = nz(close[1], close)

// fixnan - replace na with last non-na value
val4 = fixnan(close)

// Conditional na
result = close > open ? close : na

// na in expressions
sum = nz(close[1]) + nz(close[2])

plot(nz(result, 0))
