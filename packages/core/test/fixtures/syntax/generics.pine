// @test syntax/generics
// @description Generic type parsing with dotted types and multiple type arguments; nested collection templates are TV's CE10025 (probed 2026-06-05, see INV038)
// @expects parse: success
// @expects errors: 2
// @expects error: line=20, column=1, message=/Cannot use a collection in a type template/
// @expects error: line=20, column=17, message=/Cannot use a collection in a type template/

//@version=6
indicator("Generic Type Parsing Tests")

// Basic generics - array.new<T>() syntax
var floatArr = array.new<float>()
var intArr = array.new<int>()
var strArr = array.new<string>()
var boolArr = array.new<bool>()
var colorArr = array.new<color>()

// Dotted type names in generics - chart.point
var points = array.new<chart.point>()

// Multiple type arguments (map) - map.new<K, V>()
var strFloatMap = map.new<string, float>()
var intStrMap = map.new<int, string>()
var strColorMap = map.new<string, color>()

// Nested generics
var nestedArr = array.new<array<float>>()

// Matrix types
var floatMatrix = matrix.new<float>(3, 3)
var intMatrix = matrix.new<int>(2, 2)

// Using generic results
array.push(floatArr, 1.0)
array.push(intArr, 42)
map.put(strFloatMap, "key", 3.14)

plot(close)
