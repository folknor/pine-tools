        'red'               => #f2241f
        'red-bg'            => #3c2a2c
        'red-bg-s'          => #512e31
        'blue'              => #4f97d7
        'blue-bg'           => #293239
        'blue-bg-s'         => #2d4252
        'magenta'           => #a31db1
        'purple'            => #a31db1 // copied magenta
        'yellow'            => #b1951d
        'yellow-bg'         => #32322c
        'black'             => #1e2023
