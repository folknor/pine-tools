    switch _color
        'yellow'            => #e5d67c
        'blue'              => #94c4d1
        'lightgreen'        => #8bb48f
        'green'             => #1a413a
        'pink'              => #fce7d9
        'up'                => #e5d67c
        'down'              => #94c4d1
        => na

