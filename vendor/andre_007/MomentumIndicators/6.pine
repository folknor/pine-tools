	[smi, signal, histogram] = smi(nvi, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 		Stochastic Momentum Index of Momentum (MOM).
// @param source 		(float) Source for MOM
// @param length 		(int) Period of loopback for MOM
// @param shortLengthTSI 	(int) Short length for TSI
// @param longLengthTSI	 	(int) Long length for TSI
// @param maTypeTSI 		(int) Type of Moving Average for TSI
// @param maTypeTSI 		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI 	(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI 	(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiMom(
  // MOM settings
  float source, simple int length,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

    mom = ta.mom(source, length)

    [smi, signal, histogram] = smi(mom, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
      lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// #endregion }
// ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■


// ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
// RSI variations {

// @function 	RSI (Relative Strengh Index) for Volume. In this variation, the oscillator is calculated based on volume instead of price.
// @param length 	  	(int) Period of loopback
// @returns 		    (float) Series of RSI
export rsiVolume(simple int length) =>
  ta.rsi(volume, length)

// @function 	RSI (Relative Strengh Index) for Moving Average. In this variation, the oscillator is calculated based on a Moving Average instead of price.
// @param sourceMA 		(float) Source for Moving Average
// @param lengthMA 		(int) Period for Moving Average
// @param maType 	  	(int) Type of Moving Average
// @param lengthRSI 	(int) Length for RIS
// @returns 			(float) Series of RSI
export rsiMA(
  // MA Settings
  float sourceMA, simple int lengthMA, simple int maType,
  simple float almaOffset=0.85, simple float almaSigma=6, simple int lsmaOffSet=0,
  // RSI Settings
  simple int lengthRSI) =>

	ma = MAP.getMovingAverage(typeID=maType, src=sourceMA, len=lengthMA, inputAlmaOffset=almaOffset, inputAlmaSigma=almaSigma, lsmaOffset=lsmaOffSet)
	ta.rsi(ma, lengthRSI)

