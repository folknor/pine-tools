// @function 	Stochastic Momentum Index of Williams R% (Williams Percent Range)
// @param source 			(float) Source for WPR
// @param length 			(int) Length for WPR
// @param shortLengthTSI 	(int) Short length for TSI
// @param longLengthTSI	 	(int) Long length for TSI
// @param maTypeTSI 		(int) Type of Moving Average for TSI
// @param maTypeTSI 		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI 	(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI 	(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiWPR(
  // Williams R% Settings
  float source, simple int length,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	wpr = wpr(source, length)

	[smi, signal, histogram] = smi(wpr, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of FT (Fisher Transform).
// @param length 			(int) Period of loopback to calculate the Fisher Transform
// @param shortLengthTSI 	(int) Short length for TSI
// @param longLengthTSI	 	(int) Long length for TSI
// @param maTypeTSI  		(int) Type of Moving Average for TSI
// @param maTypeTSI  		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI 	(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI 	(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiFT(
  // FT settings
  simple int length,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	[ft, signal_ft] = fisher(length)

	[smi, signal, histogram] = smi(ft, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of Fisher Transform. Version with custom source
// @param sourceHigh 	 (float) Source of series for high values in Fisher Transform
// @param sourceLow 	 (float) Source of series for low values in Fisher Transform
// @param length 	  	(int) Period for loopback in Fisher Transform
// @param shortLengthTSI 	(int) Short length for TSI
// @param longLengthTSI	 	(int) Long length for TSI
// @param maTypeTSI 		(int) Type of Moving Average for TSI
// @param maTypeTSI 		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI 	(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI 	(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiFT(
  // Fisher Transform Settings
  float sourceHigh, float sourceLow, simple int length,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	[ft1, ft2] = fisher(sourceHigh, sourceLow, length)

	[smi, signal, histogram] = smi(ft1, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of CCI (Commodity Channel Index).
// @param source 	  		(float) Source for CCI
// @param length 	  		(int) Length for CCI
// @param maTypeCCI 		(int) Type of Moving Average
// @param almaOffsetCCI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaCCI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetCCI		(int) Offset for Least Squares Moving Average
// @param shortLengthTSI	(int) Short length for TSI
// @param longLengthTSI		(int) Long length for TSI
// @param maTypeTSI 		(int) Type of Moving Average for TSI
// @param maTypeTSI 		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI		(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiCCI(
  // CCI Transform Settings
  float source, simple int length,
  simple int maTypeCCI, simple float almaOffsetCCI=0.85, simple float almaSigmaCCI=6, simple int lsmaOffSetCCI=0,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	cci = cci(source, length, maTypeCCI, almaOffsetCCI, almaSigmaCCI, lsmaOffSetCCI, length, maTypeCCI)

	[smi, signal, histogram] = smi(cci, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of UO (Ultimate Oscillator).
// @param fastLength 		(int) Fast period of loopback for Ultimate Oscillator
// @param middleLength 		(int) Middle period of loopback for Ultimate Oscillator
// @param slowLength 		(int) Slow period of loopback for Ultimate Oscillator
// @param shortLengthTSI	(int) Short length for TSI
// @param longLengthTSI		(int) Long length for TSI
// @param maTypeTSI			(int) Type of Moving Average for TSI
// @param maTypeTSI			(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI		(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiUO(
  // Ultimate Oscillator Settings
  simple int fastLength, simple int middleLength, simple int slowLength,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	uo = ultimateOscillator(fastLength, middleLength, slowLength)

	[smi, signal, histogram] = smi(uo, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of MACD (Moving Average Convergence/Divergence).
// @param source			(float) Source of series for MACD (close, high, low, etc.)
// @param fastLength 		(int) Period for fast moving average for MACD
// @param slowLength 		(int) Period for slow moving average for MACD
// @param signalLength 		(int) Signal length for MACD
// @param maTypeFast 		(int) Type of fast moving average for MACD
// @param maTypeSlow 		(int) Type of slow moving average for MACD
// @param maTypeMACD 		(int) Type of MACD moving average for MACD
// @param almaOffset 		(float) Offset for Arnaud Legoux Moving Average for MACD
// @param almaSigma 		(float) Sigma for Arnaud Legoux Moving Average for MACD
// @param lsmaOffSet 		(int) Offset for Least Squares Moving Average for MACD
// @param shortLengthTSI	(int) Short length for TSI
// @param longLengthTSI		(int) Long length for TSI
// @param maTypeTSI			(int) Type of Moving Average for TSI
// @param maTypeTSI			(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI		(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with TSI, signal of TSI and histogram of difference
export smiMACD(
  // MACD settings
  float source, simple int fastLength, simple int slowLength, simple int signalLength,
  simple int maTypeFast, simple int maTypeSlow, simple int maTypeMACD,
  simple float almaOffset=0.85, simple float almaSigma=6,
  simple int lsmaOffSet=0,
  // SMI Settings
  simple int shortLengthTSI, simple int longLengthTSI,
  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	[macd, signal_macd, histogram_macd] = macd(source, fastLength, slowLength, signalLength, maTypeFast, maTypeSlow, maTypeMACD,
	  almaOffset, almaSigma, lsmaOffSet)

	[smi, signal, histogram] = smi(macd, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index (SMI) of Volume
// @param shortLengthTSI 	(int) Short length for TSI
// @param longLengthTSI	 	(int) Long length for TSI
// @param maTypeTSI	 		(int) Type of Moving Average for TSI
// @param maTypeTSI	 		(int) Type of Moving Average for Signal of TSI
// @param almaOffsetTSI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaTSI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetTSI		(int) Offset for Least Squares Moving Average
