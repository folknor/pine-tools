  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    [macd, signal, histogram] = macd(source, fastLength, slowLength, signalLength, maTypeFast, maTypeSlow, maTypeMACD,
	  almaOffset, almaSigma, lsmaOffSet)
	[k, d] = stoch(macd, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

