  simple int maTypeTSI,
  simple float almaOffsetTSI=0.85, simple float almaSigmaTSI=6,
  simple int lsmaOffSetTSI=0,

  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

	[smi, signal, histogram] = smi(volume, shortLengthTSI, longLengthTSI, maTypeTSI, almaOffsetTSI, almaSigmaTSI,
	  lsmaOffSetTSI, maTypeSignal, smoothingLengthSignal, almaOffsetSignal, almaSigmaSignal, lsmaOffSetSignal)

// @function 	Stochastic Momentum Index of MFI (Money Flow Index)
// @param length 			(int) Period for loopback for MFI
// @param lengthK           (int) Length for K%. Lengh for calculate SMI's oscillator.
// @param lengthD	        (int) Length for D%. lengh for smoothing SMI's oscillator.
// @param maTypeSMI 		(int) Type of Moving Average for SMI
// @param maTypeSMI 		(int) Type of Moving Average for Signal of SMI
// @param almaOffsetSMI		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaSMI		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetSMI		(int) Offset for Least Squares Moving Average
// @returns 				[float, float, float] A tuple with SMI, signal of SMI and histogram of difference
export smiMFI(
  // MFI settings
  simple int length,
  // SMI Settings
  simple int lengthK, simple int lengthD,
  simple int maTypeSMI,
  simple float almaOffsetSMI=0.85, simple float almaSigmaSMI=6,
  simple int lsmaOffSetSMI=0,
  // Signal Settings
  simple int maTypeSignal, simple int smoothingLengthSignal,
  simple float almaOffsetSignal=0.85, simple float almaSigmaSignal=6,
  simple int lsmaOffSetSignal=0) =>

    mfi = VI.mfi(source=close, length=length)

    [smi, signal, histogram] = smi(source=mfi, lengthK=lengthK, lengthD=lengthD, maTypeSMI=maTypeSMI, almaOffsetSMI=almaOffsetSMI,
      almaSigmaSMI=almaSigmaSMI, lsmaOffSetSMI=lsmaOffSetSMI, maTypeSignal=maTypeSignal, smoothingLengthSignal=smoothingLengthSignal,
      almaOffsetSignal=almaOffsetSignal, almaSigmaSignal=almaSigmaSignal, lsmaOffSetSignal=lsmaOffSetSignal)

