// Derivations of Stochastic Oscillator {

// @function  Stochastic of RSI (Relative Strengh Index).
//    Combination of the RSI and Stochastic Oscillator to help identify possible reversal points.
// @param sourceRSI 		(float) Source for RSI
// @param lengthRSI 		(int) Period of loopback for RSI
// @param kLength 		  	(int) Period of loopback to calculate the stochastic
// @param kSmoothing 	  	(int) Period for smoothig stochastic
// @param dSmoothing 	  	(int) Period for signal (moving average of stochastic)
// @param maTypeK 		  	(int) Type of Moving Average for Stochastic Oscillator
// @param maTypeD 		  	(int) Type of Moving Average for Stochastic Oscillator Signal
// @param almaOffsetKD 		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaKD 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetKD 		(int) Offset for Least Squares Moving Average
// @returns 				[float, float] A tuple of Stochastic Oscillator and Moving Average of Stochastic Oscillator
export stochRsi(
  // RSI settings
  float sourceRSI, simple int lengthRSI,
  // Stoch settings
  simple int kLength, simple int kSmoothing, simple int dSmoothing,
  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    rsi = rsi(sourceRSI, lengthRSI)
    [k, d] = stoch(rsi, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

// @function  Stochastic of ROC (Rate of Change).
// @param sourceROC 		(float) Source for ROC
// @param lengthROC 		(int) Period of loopback for ROC
// @param kLength 		  	(int) Period of loopback to calculate the stochastic
// @param kSmoothing 	  	(int) Period for smoothig stochastic
// @param dSmoothing 	  	(int) Period for signal (moving average of stochastic)
// @param maTypeK 		  	(int) Type of Moving Average for Stochastic Oscillator
// @param maTypeD 		  	(int) Type of Moving Average for Stochastic Oscillator Signal
// @param almaOffsetKD 		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaKD 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetKD 		(int) Offset for Least Squares Moving Average
// @returns					[float, float] A tuple of Stochastic Oscillator and Moving Average of Stochastic Oscillator
export stochRoc(
  // ROC settings
  float sourceROC, simple int lengthROC,
  // Stoch settings
  simple int kLength, simple int kSmoothing, simple int dSmoothing,
  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    roc = roc(sourceROC, lengthROC)
    [k, d] = stoch(roc, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

// @function  Stochastic of UO (Ultimate Oscillator).
// @param fastLength 		(int) Fast period of loopback for UO
// @param middleLength 		(int) Middle period of loopback for UO
// @param slowLength 	  	(int) Slow period of loopback for UO
// @param kLength 		  	(int) Period of loopback to calculate the stochastic
// @param kSmoothing 	  	(int) Period for smoothig stochastic
// @param dSmoothing 	  	(int) Period for signal (moving average of stochastic)
// @param maTypeK 		  	(int) Type of Moving Average for Stochastic Oscillator
// @param maTypeD 		  	(int) Type of Moving Average for Stochastic Oscillator Signal
// @param almaOffsetKD 		(float) Offset for Arnaud Legoux Moving Average
// @param almaSigmaKD 		(float) Sigma for Arnaud Legoux Moving Average
// @param lsmaOffSetKD 		(int) Offset for Least Squares Moving Average
// @returns 				[float, float] A tuple of Stochastic Oscillator and Moving Average of Stochastic Oscillator
export stochUO(
  // UO settings
  simple int fastLength, simple int middleLength, simple int slowLength,
  // Stoch settings
  simple int kLength, simple int kSmoothing, simple int dSmoothing,
  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    uo = ultimateOscillator(fastLength, middleLength, slowLength)
	[k, d] = stoch(uo, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

// @function  Stochastic of TSI (True Strengh Index).
// @param source 			(float) Source of series for TSI (close, high, low, etc.)
// @param shortLength 		(int) Short length for TSI
// @param longLength 		(int) Long length for TSI
// @param maType		    (int) Type of Moving Average for TSI
// @param almaOffset 		(float) Offset for Arnaud Legoux Moving Average in TSI
// @param almaSigma	 		(float) Sigma for Arnaud Legoux Moving Average in TSI
// @param lsmaOffSet 		(int) Offset for Least Squares Moving Average in TSI
// @param kLength 	 		(int) Period of loopback to calculate the stochastic
// @param kSmoothing  		(int) Period for smoothig stochastic
// @param dSmoothing  		(int) Period for signal (moving average of stochastic)
// @param maTypeK 	 		(int) Type of Moving Average for Stochastic Oscillator
// @param maTypeD 	 		(int) Type of Moving Average for Stochastic Oscillator Signal
// @param almaOffsetKD   	(float) Offset for Arnaud Legoux Moving Average for Stoch Oscillator and Signal
// @param almaSigmaKD   	(float) Sigma for Arnaud Legoux Moving Average for Stoch Oscillator and Signal
// @param lsmaOffSetKD   	(int) Offset for Least Squares Moving Average for Stoch Oscillator and Signal
// @returns 				[float, float] A tuple of Stochastic Oscillator and Moving Average of Stochastic Oscillator
export stochTSI(
  // TSI settings
  float source, simple int shortLength, simple int longLength,
  simple int maType, simple float almaOffset=0.85, simple float almaSigma=6, simple int lsmaOffSet=0,
  // Stoch settings
  simple int kLength, simple int kSmoothing, simple int dSmoothing,
  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    tsi = tsi(source, shortLength, longLength, maType, almaOffset, almaSigma, lsmaOffSet)
	[k, d] = stoch(tsi, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

// @function  Stochastic of Williams R%
// @param source 			(float) Source of series for Williams R% (close, high, low, etc.)
// @param length 			(int) Period of loopback for Williams R%
// @param kLength 		  	(int) Period of loopback to calculate the stochastic
// @param kSmoothing 	  	(int) Period for smoothig stochastic
// @param dSmoothing 	  	(int) Period for signal (moving average of stochastic)
// @param maTypeK 		  	(int) Type of Moving Average for Stochastic Oscillator
// @param maTypeD 		  	(int) Type of Moving Average for Stochastic Oscillator Signal
// @param almaOffsetKD 		(float) Offset for Arnaud Legoux Moving Average for Stoch Oscillator and Signal
// @param almaSigmaKD 		(float) Sigma for Arnaud Legoux Moving Average for Stoch Oscillator and Signal
// @param lsmaOffSetKD 		(int) Offset for Least Squares Moving Average for Stoch Oscillator and Signal
// @returns					[float, float] A tuple of Stochastic Oscillator and Moving Average of Stochastic Oscillator
export stochWPR(
  // Williams R% settings
  float source, simple int length,
  // Stoch settings
  simple int kLength, simple int kSmoothing, simple int dSmoothing,
  simple int maTypeK, simple int maTypeD,
  simple float almaOffsetKD=0.85, simple float almaSigmaKD=6, simple int lsmaOffSetKD=0) =>

    wpr = wpr(source, length)
	[k, d] = stoch(wpr, kLength, kSmoothing, dSmoothing, maTypeK, maTypeD, almaOffsetKD, almaSigmaKD, lsmaOffSetKD)

