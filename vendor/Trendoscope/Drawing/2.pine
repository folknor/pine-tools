method get(Box this, string key) =>
    key == 'p1' ? this.p1.tostring() : key == 'p2' ? this.p2.tostring() : key == 'properties' ? this.properties.tostring() : key == 'textProperties' ? this.textProperties.tostring() : na

// @function Converts DrawingTypes/Box object to string representation
// @param this DrawingTypes/Box object
