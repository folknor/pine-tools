// @function Replace the first instance of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToStringMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace(simple string this, map<string, string> stringToStringMap) =>
    string outStr = this
    for [key, value] in stringToStringMap
        if not na(value)
            outStr := str.replace(outStr, key, value)
    outStr

// @function Replace the first instance of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToStringMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace(string this, map<string, string> stringToStringMap) =>
    string outStr = this
    for [key, value] in stringToStringMap
        if not na(value)
            outStr := str.replace(outStr, key, value)
    outStr

// @function Replace the first instance of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToNumMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace(simple string this, map<string, float> stringToNumMap) =>
    string outStr = this
    for [key, value] in stringToNumMap
        if not na(value)
            outStr := str.replace(outStr, key, str.tostring(value))
    outStr

// @function Replace the first instance of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToNumMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace(string this, map<string, float> stringToNumMap) =>
    string outStr = this
    for [key, value] in stringToNumMap
        if not na(value)
            outStr := str.replace(outStr, key, str.tostring(value))
    outStr

// @function Replace all the instances of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToStringMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace_all(simple string this, map<string, string> stringToStringMap) =>
    string outStr = this
    for [key, value] in stringToStringMap
        if not na(value)
            outStr := str.replace_all(outStr, key, value)
    outStr

// @function Replace all the instances of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToStringMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace_all(string this, map<string, string> stringToStringMap) =>
    string outStr = this
    for [key, value] in stringToStringMap
        if not na(value)
            outStr := str.replace_all(outStr, key, value)
    outStr

// @function Replace all the instances of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToNumMap The amp with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace_all(simple string this, map<string, float> stringToNumMap) =>
    string outStr = this
    for [key, value] in stringToNumMap
        if not na(value)
            outStr := str.replace_all(outStr, key, str.tostring(value))
    outStr

// @function Replace all the instances of the key sub-string found in the str string with the corresponding value string
// @param this The string that will be modified if it contains the key sub-strings
// @param stringToNumMap The map with the key value pairs to be replaced
// @returns series of strings with the replaced sub-strings
export method replace_all(string this, map<string, float> stringToNumMap) =>
    string outStr = this
    for [key, value] in stringToNumMap
        if not na(value)
            outStr := str.replace_all(outStr, key, str.tostring(value))
    outStr

// @function Make a string by repeating the same string num times
// @param this The string that will be repeated
// @param num The number this string will be repeated
// @returns string result by repeating the initial string
method repeat(simple string this, simple int num) =>
    string tempStr = ''
    for i = 0 to num > 0 ? num - 1 : na
        tempStr := tempStr + this
    tempStr

// @function Make a string by repeating the same string num times
// @param this The string that will be repeated
// @param num The number this string will be repeated
// @returns string result by repeating the initial string
method repeat(string this, int num) =>
    string tempStr = ''
    for i = 0 to num > 0 ? num - 1 : na
        tempStr := tempStr + this
    tempStr

// Special characters
const string EMSP = 'вЂѓ'
const string ZWSP = 'вЂ‹'
const string ZWNJ = 'вЂЊ'
const string WJ = 'вЃ '
const string ZWNBSP = 'п»ї'

// @function Make a string by prepending a number of "special space characters"
// @param this The string that will be modified with the identation characters
// @param size The number of "special space characters"
// @returns string prepended with the "special space characters"
export method indent(simple string this, simple int size) =>
    EMSP.repeat(size) + this

// @function Make a string by prepending a number of "special space characters"
// @param this The string that will be modified with the identation characters
// @param size The number of "special space characters"
// @returns string prepended with the "special space characters"
export method indent(string this, simple int size) =>
    EMSP.repeat(size) + this

// @function Make a string by appending a number of "special space characters"
// @param this The string that will be modified with the filling characters
// @param size The number of "special space characters"
// @returns string appended with the "special space characters"
export method fill(simple string this, simple int size) =>
    this + EMSP.repeat(size)

// @function Make a string by appending a number of "special space characters"
// @param this The string that will be modified with the filling characters
// @param size The number of "special space characters"
// @returns string appended with the "special space characters"
export method fill(string this, simple int size) =>
    this + EMSP.repeat(size)

