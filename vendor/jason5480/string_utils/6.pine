// @function Get the map with the special characters that represent ASCII printable characters with codes 32-127
// @returns A map with the sequense of special characters and their corresponding printable characters
getLexicon() =>
    const map<string, string> LEXICON = map.new<string, string>()
    // Lowercase letters 97-122
    LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂЊ', 'a'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂ‹', 'b'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂЊ', 'c'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂ‹', 'd')
    LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂЊ', 'e'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂЊвЂ‹', 'f'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂЊвЂЊ', 'g'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂ‹', 'h')
    LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂЊ', 'i'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂЊвЂ‹', 'j'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂЊвЂЊ', 'k'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂ‹вЂ‹', 'l')
    LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂ‹вЂЊ', 'm'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂЊвЂ‹', 'n'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂЊвЂЊ', 'o'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂ‹', 'p')
    LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂЊ', 'q'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂЊвЂ‹', 'r'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂЊвЂЊ', 's'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂ‹вЂ‹', 't')
    LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂ‹вЂЊ', 'u'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂЊвЂ‹', 'v'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂЊвЂЊ', 'w'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂ‹вЂ‹', 'x')
    // Upercase letters 65-90
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂЊ', 'A'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂЊвЂ‹', 'B'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂЊвЂЊ', 'C'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂ‹вЂ‹', 'D')
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂ‹вЂЊ', 'E'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂЊвЂ‹', 'F'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂЊвЂЊ', 'G'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂ‹вЂ‹', 'H')
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂ‹вЂЊ', 'I'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂЊвЂ‹', 'J'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂЊвЂЊ', 'K'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂ‹вЂ‹', 'L')
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂ‹вЂЊ', 'M'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂЊвЂ‹', 'N'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂЊвЂЊ', 'O'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂ‹вЂ‹', 'P')
    LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂ‹вЂЊ', 'Q'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂЊвЂ‹', 'R'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂЊвЂЊ', 'S'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂ‹вЂ‹', 'T')
    LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂ‹вЂЊ', 'U'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂЊвЂ‹', 'V'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂЊвЂЊ', 'W'), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂ‹вЂ‹', 'X')
    LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂ‹вЂЊ', 'Y'), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂЊвЂ‹', 'Z')
    LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂ‹вЂЊ', 'y'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂЊвЂ‹', 'z')
    // Numbers 48-57
    LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂ‹', '0'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂЊ', '1'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂ‹', '2'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂЊвЂЊ', '3')
    LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂ‹', '4'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂ‹вЂЊ', '5'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂ‹', '6'), LEXICON.put('вЂЊвЂЊвЂ‹вЂЊвЂЊвЂЊ', '7')
    LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂ‹', '8'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂ‹вЂЊ', '9')
    // Symbols 32-56, 58-64, 91-96, 123-127
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂ‹', ' '), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂЊ', '!'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂ‹', '"'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂЊвЂЊ', '#')
    LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂ‹', '$'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂ‹вЂЊ', '%'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂ‹', '&'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂЊвЂЊвЂЊ', "'")
    LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂ‹', '('), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂ‹вЂЊ', ')'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂ‹', '*'), LEXICON.put('вЂЊвЂ‹вЂЊвЂ‹вЂЊвЂЊ', '+')
    LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂ‹', ','), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂЊ', '-'), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂ‹', '.'), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂЊ', '/')
    LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂ‹', ':'), LEXICON.put('вЂЊвЂЊвЂЊвЂ‹вЂЊвЂЊ', ';'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂ‹', '<'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂЊ', '=')
    LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂ‹', '>'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂЊ', '?'), LEXICON.put('вЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹', '@'),
    LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂ‹вЂЊвЂЊ', '['), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂ‹вЂ‹', '\\'),LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂ‹вЂЊ', ']'), LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂЊвЂ‹', '^')
    LEXICON.put('вЂЊвЂ‹вЂЊвЂЊвЂЊвЂЊвЂЊ', '_'), LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂ‹', '`')
    LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂ‹вЂЊвЂЊ', '{'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂ‹вЂ‹', '|'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂ‹вЂЊ', '}'), LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂЊвЂ‹', '~')
    LEXICON.put('вЂЊвЂЊвЂЊвЂЊвЂЊвЂЊвЂЊ', 'DEL')
    // Symbol 169
    LEXICON.put('вЂЊвЂЊвЂ‹вЂ‹вЂ‹вЂ‹вЂЊвЂ‹', 'В©')
    LEXICON

// @function Convert a public message to it's private equivalent using the steganograph techinque described here https://neatnik.net/steganographr/
// @param this The string (public message) to be desteganographized
// @returns The private message
export method desteganographize(simple string this) =>
    string message = this
    string privStr = str.match(this, '[вЂ‹вЂЊвЃ ]+')
    if str.length(privStr) == 0
        log.warning('No private message was detected in the given public message')
    else
        var const map<string, string> LEXICON = getLexicon()
        array<string> privLetters = str.split(privStr, WJ)
        message := ''
        for let in privLetters
            message := message + LEXICON.get(let)
    message

// @function Print the string in the main chart
// @param this The string to be printed to the chart
// @param height The height of the cell as a percentage of the charts height. By default, 0 auto-adjusts the height based on the text inside the cell
// @param textColor The color of the text
// @param textSize The size of the text
// @param position Position of the table
// @returns The table that has the string
export method announce(simple string this, simple float height = 0., color textColor = chart.fg_color, simple string textSize = size.large, simple string position = position.top_center) =>
    var const table announceTable = table.new(position = position, rows = 1, columns = 1, force_overlay = true)
    announceTable.cell(row = 0, column = 0, text = this, height = height, text_color = textColor, text_size = textSize)
    announceTable

// @function Print the string in the main chart
// @param this The string to be printed to the chart
// @param height The height of the cell as a percentage of the charts height. By default, 0 auto-adjusts the height based on the text inside the cell
// @param textColor The color of the text
// @param textSize The size of the text
// @param position Position of the table
// @returns The table that has the string
export method announce(string this, simple float height = 0., color textColor = chart.fg_color, simple string textSize = size.large, simple string position = position.top_center) =>
    var const table announceTable = table.new(position = position, rows = 1, columns = 1, force_overlay = true)
    announceTable.cell(row = 0, column = 0, text = this, height = height, text_color = textColor, text_size = height == 0 ? textSize : size.auto)
    announceTable

// @function Print the map in the main chart as a legend
// @param this The map with the item and explanation to be printed to the chart
// @param maxRows The maximum number of table rows
// @param height The height of the legend as a percentage of the charts height. By default, 0 auto-adjusts the height based on the text inside the cells
// @param textColor The color of the text
// @param textSize The size of the text
// @param position Position of the table
// @returns The table that has the string
export method legend(map<string, string> this, int maxRows = 3, simple float height = 0., color textColor = chart.fg_color, simple string textSize = size.small, simple string position = position.bottom_center) =>
    int rows = math.min(maxRows, this.size())
    int columns = 2 * math.ceil(this.size() / rows)
    float cellHeight = height / rows
    string celTextSize = height == 0 ? textSize : size.auto
    var const table legendTable = table.new(position = position, rows = rows, columns = columns, force_overlay = true)
    int i = 0
    int j = 0
    for [sym, txt] in this
        legendTable.cell(row = i, column = j, text = sym, height = cellHeight, text_color = textColor, text_size = celTextSize, text_halign = text.align_right)
        legendTable.cell(row = i, column = j + 1, text = txt, height = cellHeight, text_color = textColor, text_size = celTextSize, text_halign = text.align_left)
        i += 1
        if i >= rows
            i := 0
            j += 2
    legendTable

