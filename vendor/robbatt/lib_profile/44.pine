// v354 (v1) feature complete, optimisation todo
// v453 (v5) fixed max_bars_back through not updating box left and line start x coordinates on re-draw, added lines to mark candle ranges used for profile
// v1234 (v24) refactored draw system

//@version=6
import PineCoders/Time/4
import robbatt/lib_plot_objects/56 as D
import robbatt/lib_set/1

// @description a library with functions to calculate a volume profile for either a set of candles within the current chart, or a single candle from its lower timeframe security data. All you need is to feed the 
library("lib_profile", overlay = true)
varip int tickid = 0
tickid += 1

//@description this is a container for each bucket of the Profile. See Profile description for more info
//@field idx the index of this Bucket within the Profile starting with 0 for the lowest Bucket at the bottom of the Profile
//@field value the value of this Bucket, can be volume or time, for using time pass and array of 1s to the update function
//@field top the top of this Bucket's price range (for calculation)
//@field btm the bottom of this Bucket's price range (for calculation)
//@field center the center of this Bucket's price range (for plotting)
//@field fraction the fraction this Bucket's value is compared to the total of the Profile
//@field plot_bucket_line the line that resembles this bucket and it's valeu in the Profile
export type Bucket
	varip int idx
	varip float value
	varip float top
	varip float btm
	varip float center
	varip float fraction
	D.Line plot_bucket_line

//@function updates this bucket's data
export method update(Bucket this, float top, float bottom, float value, float fraction) =>
	rounded_top    = math.round_to_mintick(top)
	rounded_bottom = math.round_to_mintick(bottom)
	fraction_rounded = math.round(fraction, 2)
	if na(this.center) or this.top != rounded_top or this.btm != rounded_bottom or this.value != value and this.fraction != fraction_rounded // value: self changed / fraction: others changed (also rounded -> significant change)
		this.top := rounded_top    
		this.btm := rounded_bottom 
		this.center := math.avg(rounded_top, rounded_bottom)
		this.value := value
		this.fraction := fraction_rounded
	this

//@function updates this bucket's data
export method update(Bucket this, float value, float fraction) =>
	fraction_rounded = math.round(fraction, 2)
	if this.value != value or this.fraction != fraction_rounded // value: self changed / fraction: others changed (also rounded -> significant change)
		this.value := value
		this.fraction := fraction_rounded
	this

//@function allows drawing a line in a Profile, representing this bucket and it's value + it's value's fraction of the Profile total value
//@param start_t the time x coordinate of the line's left end (depends on the Profile box)
//@param start_i the bar_index x coordinate of the line's left end (depends on the Profile box)
//@param end_t the time x coordinate of the line's right end (depends on the Profile box)
//@param end_i the bar_index x coordinate of the line's right end (depends on the Profile box)
//@param args the default arguments for the line style and colors
draw_bucket(Bucket this, int start_t, int start_i, int end_t, int end_i, D.LineArgs args, bool extend_only = true, simple bool force_overlay = false) =>
	if na(this) ? false : not na(this.plot_bucket_line)
		this.plot_bucket_line.start.update(start_t, start_i, this.center)
		this.plot_bucket_line.end.update(end_t, end_i, this.center)
		this.plot_bucket_line.draw(args, extend_only, force_overlay)		
	this

//@description arguments for plotting a Profile
//@field show_poc whether to plot a POC line across the Profile Box (default: true)
//@field show_profile whether to plot a line for each Bucket in the Profile Box, indicating the value per Bucket (Price range), e.g. volume that occured in a certain time and price range (default: false)
//@field show_va whether to plot a VAH/VAL line across the Profile Box (default: false)
//@field show_va_fill whether to fill the 'value' area between VAH/VAL line (default: false)
//@field show_background whether to fill the Profile Box with a background color (default: false)
//@field show_labels whether to add labels to the right end of the POC/VAH/VAL line (default: false)
//@field show_price_levels whether add price values to the labels to the right end of the POC/VAH/VAL line (default: false)
//@field extend whether extend the Profile Box to the current candle (default: false)
//@field args_poc_line arguments for the poc line plot
//@field args_vah_line arguments for the va line plot
//@field args_val_line arguments for the va line plot
//@field args_poc_label arguments for the poc label plot
//@field args_vah_label arguments for the va label plot
//@field args_val_label arguments for the va label plot
//@field args_profile_line arguments for the Bucket line plots
//@field va_fill_color color for the va area fill plot
export type ProfileConfig
	bool show_poc = true
	bool show_profile = false
	bool show_va = false
	bool show_va_fill = false
	bool show_background = false
	bool show_labels = false
	bool show_price_levels = false
	bool extend = false

	string poc_label_text = 'POC'
	string vah_label_text = 'VAH'
	string val_label_text = 'VAL'
	D.LineArgs args_poc_line
	D.LineArgs args_vah_line
	D.LineArgs args_val_line
	D.LabelArgs args_poc_label
	D.LabelArgs args_vah_label
	D.LabelArgs args_val_label
	D.LineArgs args_profile_line
	D.BoxArgs args_profile_bg
	color va_fill_color = color.yellow
	bool initialized = false

//@description
//@field left_top used as left x coordinate for the Profile Box and highest price value of the profile data | filled by update()
//@field right_bottom used as right x coordinate for the Profile Box and lowest price value of the profile data | filled by update()
//@field resolution the amount of buckets/price ranges the Profile will dissect the data into
//@field vah_threshold_pc the percentage of the total data value to mark the upper threshold for the main value area
//@field val_threshold_pc the percentage of the total data value to mark the lower threshold for the main value area
//@field data_opens (optional) array of range open values (either from ltf or chart candles using history() function
//@field data_closes (optional) array of range close values (either from ltf or chart candles using history() function
//@field data_highs array of range top/high values (either from ltf or chart candles using history() function
//@field data_lows array of range bottom/low values (either from ltf or chart candles using history() function
//@field data_values array of range volume/1 values (either from ltf or chart candles using history() function (1s can be used for analysing candles in bucket/price range over time)
//@field total the total data value (e.g. volume of all candles, or just one each to analyse candle distribution over time) | filled by update()
//@field total_up the total data directional value up | filled by update()
//@field total_down the total data directional value down | filled by update()
//@field use_open_close_data_for_ranges_shorter_than_bars the max. amount of candles in a range that qualifies for using open/close data for profile calculation (default: 4)
//@field buckets the Bucket objects holding the data for each price range bucket | filled by update()
//@field poc_bucket_index the Bucket index in buckets, that holds the poc Bucket | filled by update()
//@field vah_bucket_index the Bucket index in buckets, that holds the vah Bucket | filled by update()
//@field val_bucket_index the Bucket index in buckets, that holds the val Bucket | filled by update()
//@field poc the according price level marking the Point Of Control | filled by update()
//@field vah the according price level marking the Value Area High | filled by update()
//@field val the according price level marking the Value Area Low | filled by update()
//@field plot_poc | filled by draw()
//@field plot_vah | filled by draw()
//@field plot_val | filled by draw()
//@field plot_poc_label | filled by draw()
//@field plot_vah_label | filled by draw()
//@field plot_val_label | filled by draw()
//@field plot_va_fill | filled by draw()
//@field plot_profile_bg | filled by draw()
export type Profile
	// params
	int id
	int resolution
	float vah_threshold_pc
	float val_threshold_pc
	varip float[] data_opens
	varip float[] data_highs
	varip float[] data_lows
	varip float[] data_closes
	varip float[] data_values
	
	// range data
	varip float h = na
	varip float l = na
	varip float total = 0
	varip float total_up = 0
	varip float total_down = 0

	Bucket[] buckets

	// value levels
	varip int poc_bucket_index
	varip int vah_bucket_index
	varip int val_bucket_index

	// price levels
	varip float poc
	varip float vah
	varip float val

	// plots
	D.Line plot_poc
	D.Line plot_vah
	D.Line plot_val
	D.Label plot_poc_label
	D.Label plot_vah_label
	D.Label plot_val_label
	D.LineFill plot_va_fill
	D.Box plot_profile_bg

	bool hidden = false

export method apply_style(Profile this, ProfileConfig args) =>
    if not na(this) and not na(args)
        if not na(this.plot_poc)
            this.plot_poc.apply_style(args.args_poc_line)            
	    if not na(this.plot_vah)
            this.plot_vah.apply_style(args.args_vah_line)
	    if not na(this.plot_val)
            this.plot_val.apply_style(args.args_val_line)
	    if not na(this.plot_poc_label)
            this.plot_poc_label.apply_style(args.args_poc_label)
	    if not na(this.plot_vah_label)
            this.plot_vah_label.apply_style(args.args_vah_label)
	    if not na(this.plot_val_label)
            this.plot_val_label.apply_style(args.args_val_label)
	    if not na(this.plot_va_fill)
            this.plot_va_fill.plot.set_color(args.va_fill_color)
	    if not na(this.plot_profile_bg)
            this.plot_profile_bg.apply_style(args.args_profile_bg, D.BoxTextArgs.new())

//@description deletes this Profile's and Buckets' plots
export method delete(Profile this) =>
	if not na(this)
		if not na(this.buckets)
			for bucket in this.buckets
				if not na(bucket.plot_bucket_line)
					bucket.plot_bucket_line.delete()	
					bucket.plot_bucket_line := na	
		if not na(this.plot_poc)
			this.plot_poc.delete()
			this.plot_poc := na
		if not na(this.plot_vah)
			this.plot_vah.delete()
			this.plot_vah := na
		if not na(this.plot_val)
			this.plot_val.delete()
			this.plot_val := na
		if not na(this.plot_poc_label)
			this.plot_poc_label.delete()
			this.plot_poc_label := na
		if not na(this.plot_vah_label)
			this.plot_vah_label.delete()
			this.plot_vah_label := na
		if not na(this.plot_val_label)
			this.plot_val_label.delete()
			this.plot_val_label := na
		if not na(this.plot_va_fill)
			this.plot_va_fill.delete()
			this.plot_va_fill := na
		if not na(this.plot_profile_bg)
			this.plot_profile_bg.delete()
			this.plot_profile_bg := na
	this


//@function hides this Profile's plot from the chart by setting the line end to na
export method hide(Profile this) =>
	if na(this) ? false : not this.hidden
		if not na(this.buckets)
			for bucket in this.buckets
				if not na(bucket.plot_bucket_line)
					bucket.plot_bucket_line.hide()
		if not na(this.plot_poc)
			this.plot_poc.hide()
		if not na(this.plot_vah)
			this.plot_vah.hide()
		if not na(this.plot_val)
			this.plot_val.hide()
		if not na(this.plot_poc_label)
			this.plot_poc_label.hide()
		if not na(this.plot_vah_label)
			this.plot_vah_label.hide()
		if not na(this.plot_val_label)
			this.plot_val_label.hide()
		if not na(this.plot_profile_bg)
			this.plot_profile_bg.hide()
		this.hidden := true
	this

//@description deletes a list of Profiles' plots
export method delete(Profile[] this) => 
	if not na(this)
		for item in this
			item.delete()
	this

export method deepcopy(ProfileConfig this) =>
	ProfileConfig.new(this.show_poc, this.show_profile, this.show_va, this.show_va_fill, this.show_background, this.show_labels, this.show_price_levels,
	 this.extend, this.poc_label_text, this.vah_label_text, this.val_label_text, 
	 this.args_poc_line.copy(), this.args_vah_line.copy(), this.args_val_line.copy(), 
	 this.args_poc_label.copy(), this.args_vah_label.copy(), this.args_val_label.copy(), 
	 this.args_profile_line.copy(), this.args_profile_bg.copy(), 
	 this.va_fill_color, this.initialized)
	
//@description initialises ProfileConfig with default values if not set, will be called by update() and draw() to ensure both functions can work properly
export method init(ProfileConfig this) =>
	if na(this) ? false : not this.initialized
		if na(this.args_poc_line)
			this.args_poc_line := D.LineArgs.new(color.orange, line.style_dotted, 1, xloc.bar_time)
		if na(this.args_vah_line)
			this.args_vah_line := D.LineArgs.new(color.yellow, line.style_dotted, 1, xloc.bar_time)
		if na(this.args_val_line)
			this.args_val_line := D.LineArgs.new(color.yellow, line.style_dotted, 1, xloc.bar_time)
		if na(this.args_poc_label)
			this.args_poc_label := D.LabelArgs.new(color.orange, #00000000, style = label.style_label_lower_right, xloc = xloc.bar_time)
		if na(this.args_vah_label)
			this.args_vah_label := D.LabelArgs.new(color.yellow, #00000000, style = label.style_label_lower_right, xloc = xloc.bar_time)
		if na(this.args_val_label)
			this.args_val_label := D.LabelArgs.new(color.yellow, #00000000, style = label.style_label_lower_right, xloc = xloc.bar_time)
		if na(this.args_profile_line)
			this.args_profile_line := D.LineArgs.new(color.rgb(120, 123, 134, 40), line.style_dotted, 1, xloc.bar_time)
		if na(this.args_profile_bg)
			this.args_profile_bg := D.BoxArgs.new(#00000000, bg_color = color.rgb(120, 123, 134, 92), xloc = xloc.bar_time)
		this.initialized := true
	this

//@description initialises Profile with default values if not set, will be called by update() and draw() to ensure both functions can work properly
export method init(Profile this, bool update_buckets = false) =>
	if not na(this)
		create_buckets = na(this.buckets)
		if create_buckets or update_buckets
			float bucket_size = (this.h - this.l) / this.resolution

			if create_buckets
				this.buckets := array.new<Bucket>(this.resolution)
					
			for i = 0 to this.resolution - 1
				float bucket_bottom = this.l + i * bucket_size
				float bucket_top = bucket_bottom + bucket_size
				if create_buckets
					this.buckets.set(i, Bucket.new(i, 0, bucket_top, bucket_bottom, math.avg(bucket_top, bucket_bottom), 0 ))
				else // update_buckets
					this.buckets.get(i).update(bucket_top, bucket_bottom, 0, 0)					
	this

//@function recalculates this Profile's data (update() will only recalculate if new data is passed, this one forces recalculation)
export method calculate(Profile this, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
	// DATA
	// ASSUMING DATA (opens/highs/lows/closes/values/h/l/total) IS SET IN create_profile OR update_profile

	int range_count = array.size(this.data_values)
    float vah_threshold = this.total * (this.vah_threshold_pc / 100)
    float val_threshold = this.total * (this.val_threshold_pc / 100)
	float value_range = this.h - this.l
	float bucket_size = value_range / this.resolution

	// RESULTS
    if range_count > 0
        float poc_volume = 0
        float sum_volume = 0
        float sum_volume_up = 0
        float sum_volume_down = 0
    	int   range_count_opens = na(this.data_opens) ? 0 : array.size(this.data_opens)
    	int   range_count_closes = na(this.data_closes) ? 0 : array.size(this.data_closes)
		
		for i = 0 to this.resolution - 1
			Bucket bucket = this.buckets.get(i)
            float bucket_value = 0

			// check all top-btm ranges, add the value (partly) to the bucket on overlap
            for j = 0 to range_count - 1
                float range_value = array.get(this.data_values, j)
                float range_high  = array.get(this.data_highs, j)
                float range_low   = array.get(this.data_lows, j)
				float range_size  = range_high - range_low

				// optimized by claude sonnet 3.5, see original code in v753
                float overlap = math.max(0, math.min(range_high, bucket.top) - math.max(range_low, bucket.btm))

				if (i == 0 or 0 < use_open_close_data_for_ranges_shorter_than_bars) and j < range_count_opens and j < range_count_closes 

					float range_open  = array.get(this.data_opens, j)
					float range_close = array.get(this.data_closes, j)

					// improved calculation for directional volume in this block
					if i == 0
						if range_open < range_close
							sum_volume_up += range_value
						else
							sum_volume_down += range_value

					// improved fraction calculation to incorporate wicks with a weight of 2(each) and the body with a weight of 3 => 7 parts total
					if j < use_open_close_data_for_ranges_shorter_than_bars
						overlap += math.max(0, 
						 math.min(math.max(range_open, range_close), bucket.top) - 
						 math.max(math.min(range_open, range_close), bucket.btm)
						 ) / 2
						range_size += math.abs(range_open-range_close) / 2

				
                float range_value_fraction = 
				 range_size > 0 ? overlap / range_size // regular overlap, overlapped part as ratio of full bucket
				 : (overlap > 0 ? 1 : 0) // 0 division protection, if overlap detected anyway, count it fully

				bucket_value += range_value_fraction * range_value

			bucket.update(bucket_value, bucket_value / this.total)
			
            // track highest value (POC) inside the profile AND it's index 
            if bucket_value >= poc_volume
                poc_volume := bucket_value // track highest volume in profile
                this.poc_bucket_index := i
				this.poc := bucket.center

            // while going through the profile, accumulate the bucket values. As soon as we cross the value area thresholds with a bucket, we know where the value area starts / ends.
            if sum_volume < val_threshold and val_threshold <= (sum_volume + bucket_value)
                this.val_bucket_index := i
				this.val := bucket.center
            if sum_volume < vah_threshold and vah_threshold <= (sum_volume + bucket_value)
                this.vah_bucket_index := i
				this.vah := bucket.center

            sum_volume += bucket_value

		this.total_up   := sum_volume_up
		this.total_down := sum_volume_down
	this

//@function creates a new Profile
//@param start index from where to draw the Profile (left edge)
//@param end index until where to draw the Profile (right edge)
//@param opens (optional) data for profiled range's opens
//@param closes (optional) data for profiled range's closes
//@param highs data for profiled range's highs
//@param lows data for profiled range's lows
//@param values data for profiled range's value data (volume/time)
//@param resolution amount of buckets in which to split the analysis (default: 25)
//@param vah_pc Value Area High percentage (default: 80)
//@param val_pc Value Area Low percentage (default: 20)
//@param init_calculated whether to run an initial calculation on creation (POC, VAH, VAL). Set this to false if you want to have a lightweight initialization process and only calculate at a certain event (default: true)
//@param idx gives this Profile an index value to allow for easier identification in debugging/logs (default: bar_index)
export create_profile(float[] opens, float[] highs, float[] lows, float[] closes, float[] values, int resolution = 25, float vah_pc = 80, float val_pc = 20, int idx = bar_index, bool init_calculated = true, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
	profile = Profile.new(idx, resolution, vah_pc, val_pc, opens, highs, lows, closes, values, h = highs.max(), l = lows.min(), total = values.sum())
	profile.init(update_buckets = true) // init buckets
	if init_calculated
		profile.calculate(use_open_close_data_for_ranges_shorter_than_bars)	
	profile


//@function update this Profile's data (recalculates the whole profile and applies the result to this object)
//@param opens (optional) array of range open values (either from ltf or chart candles using history() function
//@param closes (optional) array of range close values (either from ltf or chart candles using history() function
//@param highs array of range top/high values (either from ltf or chart candles using history() function
//@param lows array of range bottom/low values (either from ltf or chart candles using history() function
//@param values array of range volume/1 values (either from ltf or chart candles using history() function (1s can be used for analysing candles in bucket/price range over time)
//@param end_t (optional) end time until when to consider data for the profile calculation
//@param end_i (optional) end index until when to consider data for the profile calculation
export method update(Profile this, float[] opens = na, float[] highs = na, float[] lows = na, float[] closes = na, float[] values = na) =>
	if not na(this)
		recalculation_required = false
		layout_required = false

		if not na(opens)
			this.data_opens := opens
			recalculation_required := true
		if not na(highs)
			this.data_highs := highs
			h = highs.max()
			layout_required := this.h != h
			this.h := h
			recalculation_required := true
		if not na(lows)
			this.data_lows := lows
			l = lows.min()
			layout_required := layout_required or this.l != l
			this.l := l
			recalculation_required := true
		if not na(closes)
			this.data_closes := closes
			recalculation_required := true
		if not na(values)
			this.data_values := values
			this.total := values.sum()
			recalculation_required := true		

		if layout_required
			this.init(update_buckets = true) // init buckets
		if recalculation_required or na(this.poc)			
			this.calculate()
	this

//@function draw all components of this Profile (Box, Background, Bucket lines, POC/VAH/VAL overlay levels and labels). The profile is drawn from first to last bar / start to end of the profiled bars Optional drawing from another origin is possible with draw_from_t/draw_from_i (time/bar_index). Optional the width of the drawn profile can dynamically adjusted to a number of bars via forced_width (gaps in data are not considered via xloc = bar_time). Optional with ProfileConfig.extend the profile can extend to the current bar_index (usefull for POC and Value Area lines). Optional ProfileConfig.default_size can be used to configure a shared default length for profiles.
//@param left from which bar_index/time to draw the profile. ProfileConfig.args.xloc decides which one is used
//@param right until which bar_index/time to draw the profile. ProfileConfig.args.xloc decides which one is used
//@param extend_only unless draw_from_t/draw_from_i is used and changing, this can remain at default true and the start point x coordinates will not be updated, preventing errors when drawing based on bar_index
//@param poc_text_override allows to override the text of the POC line label (price label will be added if config enables it)
export method draw(Profile this, ProfileConfig config, int left = na, int right = na, bool extend_only = true, simple bool force_overlay = false, string poc_text_override = na) =>
	var tf_ms = timeframe.in_seconds() * 1000

	if na(this) ? false : na(this.buckets) ? false : this.buckets.size() > 0
		config.init()
		this.init() 
		
		int len = right - left
		
		if config.show_background
			if na(this.plot_profile_bg)			
				this.plot_profile_bg := D.create_box(left, this.h, right, this.l, config.args_profile_bg.xloc)
			else				
				this.plot_profile_bg.left_top.update(left, this.h, config.args_profile_bg.xloc)
				this.plot_profile_bg.right_bottom.update(right, this.l, config.args_profile_bg.xloc)
			this.plot_profile_bg.draw(config.args_profile_bg, na, extend_only, force_overlay)
						
		if config.show_profile
			poc_bucket = this.buckets.get(this.poc_bucket_index)

			for bucket in this.buckets				
				if not na(bucket) and not na(poc_bucket)
					int bucket_len = math.ceil(len * bucket.value / poc_bucket.value)
					int bucket_end = left + bucket_len
					
					bucket_args = 
					 bucket.idx == this.poc_bucket_index ? config.args_poc_line : 
					 bucket.idx == this.vah_bucket_index ? config.args_vah_line :
					 bucket.idx == this.val_bucket_index ? config.args_val_line : 
					 config.args_profile_line

					if na(bucket.plot_bucket_line)
						bucket.plot_bucket_line := D.create_line(left, bucket.center, bucket_end, bucket.center, bucket_args.xloc).draw(bucket_args, extend_only, force_overlay)
					else
						bucket.plot_bucket_line.start.update(left, bucket.center, bucket_args.xloc)
						bucket.plot_bucket_line.end.update(bucket_end, bucket.center, bucket_args.xloc)
						bucket.plot_bucket_line.draw(bucket_args, extend_only, force_overlay)	
						bucket.plot_bucket_line.plot.set_color(bucket_args.line_color) // on draw color is not updated

		if config.show_poc
			if na(this.plot_poc)
				this.plot_poc := D.create_line(left, this.poc, right, this.poc, config.args_poc_line.xloc)
			else
				this.plot_poc.start.update(left, this.poc, config.args_poc_line.xloc)
				this.plot_poc.end.update(right, this.poc, config.args_poc_line.xloc)
			this.plot_poc.draw(config.args_poc_line, extend_only, force_overlay)

			if config.show_labels
				tooltip = str.format('{0} ({1})', na(poc_text_override) ? config.poc_label_text : poc_text_override, this.poc)
				txt = config.show_price_levels ? tooltip : na(poc_text_override) ? config.poc_label_text : poc_text_override
				if na(this.plot_poc_label)
					this.plot_poc_label := D.create_label(D.create_point(right, this.poc, config.args_poc_label.xloc), txt, tooltip)
				else
					this.plot_poc_label.point.update(right, this.poc, config.args_poc_label.xloc)
					this.plot_poc_label.txt := txt
					this.plot_poc_label.tooltip := tooltip
				this.plot_poc_label.draw(config.args_poc_label, force_overlay)

		if config.show_va
			if na(this.plot_vah)
				this.plot_vah := D.create_line(left, this.vah, right, this.vah, config.args_vah_line.xloc)
			else
				this.plot_vah.start.update(left, this.vah, config.args_vah_line.xloc)
				this.plot_vah.end.update(right, this.vah, config.args_vah_line.xloc)
			this.plot_vah.draw(config.args_vah_line, extend_only, force_overlay)
				
			if na(this.plot_val)
				this.plot_val := D.create_line(left, this.val, right, this.val, config.args_val_line.xloc)
			else
				this.plot_val.start.update(left, this.val, config.args_val_line.xloc)
				this.plot_val.end.update(right, this.val, config.args_val_line.xloc)
			this.plot_val.draw(config.args_val_line, extend_only, force_overlay)

			if config.show_labels
				vah_tooltip = str.format('{0} ({1})', config.vah_label_text, this.vah)
				vah_txt = config.show_price_levels ? vah_tooltip : config.vah_label_text

				val_tooltip = str.format('{0} ({1})', config.val_label_text, this.val)
				val_txt = config.show_price_levels ? val_tooltip : config.val_label_text

				if na(this.plot_vah_label)
					this.plot_vah_label := D.create_label(D.create_point(right, this.vah, config.args_vah_label.xloc), vah_txt, vah_tooltip)
				else
					this.plot_vah_label.point.update(right, this.vah, config.args_vah_label.xloc)
					this.plot_vah_label.txt := vah_txt
					this.plot_vah_label.tooltip := vah_tooltip
				this.plot_vah_label.draw(config.args_vah_label, force_overlay)

				if na(this.plot_val_label)
					this.plot_val_label := D.create_label(D.create_point(right, this.val, config.args_val_label.xloc), val_txt, val_tooltip)
				else
					this.plot_val_label.point.update(right, this.val, config.args_val_label.xloc)
					this.plot_val_label.txt := val_txt
					this.plot_val_label.tooltip := val_tooltip
				this.plot_val_label.draw(config.args_val_label, force_overlay)

			if config.show_va_fill 
				if na(this.plot_va_fill)
					this.plot_va_fill := D.create_fill(this.plot_val, this.plot_vah, config.va_fill_color)
		this.hidden := false
	this

//@function creates a copy of this bucket and it's plot object
export method deep_copy(Bucket this) =>
	Bucket.new(this.idx, this.value, this.top, this.btm, this.center, this.fraction, this.plot_bucket_line.deep_copy())

//@function creates copies of all buckets including their plot objects
export method deep_copy(Bucket[] this) =>
	copy = array.new<Bucket>(this.size())
	for i = 0 to this.size() - 1
		copy.set(i, this.get(i).deep_copy())
	copy	

//@function creates a copy of this Profile and all it's buckets and plot objects
export method deep_copy(Profile this) =>
	Profile.new(this.id, this.resolution, this.vah_threshold_pc, this.val_threshold_pc, 
	 this.data_opens.copy(), this.data_highs.copy(), this.data_lows.copy(), this.data_closes.copy(), this.data_values.copy(), 
	 this.h, this.l, this.total, this.total_up, this.total_down, this.buckets.deep_copy(), 
	 this.poc_bucket_index, this.vah_bucket_index, this.val_bucket_index, 
	 this.poc, this.vah, this.val, 
	 this.plot_poc.deep_copy(), this.plot_vah.deep_copy(), this.plot_val.deep_copy(), 
	 this.plot_poc_label.deep_copy(), this.plot_vah_label.deep_copy(), this.plot_val_label.deep_copy(), 
	 this.plot_va_fill.deep_copy(), this.plot_profile_bg.deep_copy()
	 )

//@function resets all data and plot objects for reuse
method reset(Bucket[] this) =>
	for bucket in this
		bucket.value := 0
		bucket.fraction := 0
		if not na(bucket.plot_bucket_line)
			bucket.plot_bucket_line.update(chart.point.now(bucket.center), chart.point.now(bucket.center))

// @function resets all data and plot objects for reuse
export method reset(Profile this) =>	
	// this.id // keep it
	// this.resolution // keep it
	// this.vah_threshold_pc // keep it
	// this.val_threshold_pc // keep it
	this.data_opens.clear()
	this.data_closes.clear()
	this.data_highs.clear()
	this.data_lows.clear()
	this.data_values.clear()

	// range data
	this.h := high
	this.l := low
	this.total := volume
	this.total_up 	:= open < close ? volume : 0
	this.total_down := open > close ? volume : 0
	this.buckets.reset()

	// value levels
	this.poc_bucket_index := na
	this.vah_bucket_index := na
	this.val_bucket_index := na

	// price levels
	this.poc := na
	this.vah := na
	this.val := na

	// plots
	if not na(this.plot_poc)
		this.plot_poc.update(chart.point.now(close), chart.point.now(close))		
		if not na(this.plot_poc.plot)
			this.plot_poc.plot := this.plot_poc.plot.copy()
			this.plot_poc.plot.set_first_point(this.plot_poc.start)
			this.plot_poc.plot.set_second_point(this.plot_poc.end)
	if not na(this.plot_vah)
		this.plot_vah.update(chart.point.now(close), chart.point.now(close))
		if not na(this.plot_vah.plot)
			this.plot_vah.plot := this.plot_vah.plot.copy()
			this.plot_vah.plot.set_first_point(this.plot_vah.start)
			this.plot_vah.plot.set_second_point(this.plot_vah.end)
	if not na(this.plot_val)
		this.plot_val.update(chart.point.now(close), chart.point.now(close))
		if not na(this.plot_val.plot)
			this.plot_val.plot := this.plot_val.plot.copy()
			this.plot_val.plot.set_first_point(this.plot_val.start)
			this.plot_val.plot.set_second_point(this.plot_val.end)
	if not na(this.plot_poc_label)
		this.plot_poc_label.update(chart.point.now(na))
		if not na(this.plot_poc_label.plot)
			this.plot_poc_label.plot.set_point(this.plot_poc_label.point)
	if not na(this.plot_vah_label)
		this.plot_vah_label.update(chart.point.now(na))
		if not na(this.plot_vah_label.plot)
			this.plot_vah_label.plot.set_point(this.plot_vah_label.point)
	if not na(this.plot_val_label)
		this.plot_val_label.update(chart.point.now(na))
		if not na(this.plot_val_label.plot)
			this.plot_val_label.plot.set_point(this.plot_val_label.point)
	if not na(this.plot_profile_bg)
		this.plot_profile_bg.update(chart.point.now(high), chart.point.from_index(bar_index + 1, low))

