var resolution = input.int(20, 'resolution')
var vah_pc = input.float(80, 'VAH %')
var val_pc = input.float(20, 'VAL %')


varip ProfileConfig args = ProfileConfig.new(
 show_poc = input.bool(true, 'show POC', inline = 'poc'), 
 args_poc_line = D.LineArgs.new(input.color(color.orange, '', inline = 'poc'), line.style_dashed, 1, xloc.bar_time), 

 show_va = input.bool(true, 'Value Area', inline = 'va'), 
 args_vah_line = D.LineArgs.new(input.color(color.yellow, '', inline = 'va'), line.style_dotted, 1, xloc.bar_time), 
 args_val_line = D.LineArgs.new(input.color(color.yellow, '', inline = 'va'), line.style_dotted, 1, xloc.bar_time), 
 show_va_fill = input.bool(true, 'fill', inline = 'va'), 
 va_fill_color = input.color(#ffeb3b0e, '', inline = 'va'),

 show_labels = input.bool(true, 'Show labels', inline = 'labels'),
 show_price_levels = input.bool(true, 'with price', inline = 'labels'),
 args_poc_label = D.LabelArgs.new(input.color(color.orange, '', inline = 'labels'), #00000000, xloc = xloc.bar_time, style = label.style_label_left, size = size.tiny), 
 args_vah_label =  D.LabelArgs.new(input.color(color.yellow, '', inline = 'labels'), #00000000, xloc = xloc.bar_time, style = label.style_label_left, size = size.tiny), 
 args_val_label =  D.LabelArgs.new(input.color(color.yellow, '', inline = 'labels'), #00000000, xloc = xloc.bar_time, style = label.style_label_left, size = size.tiny), 

 show_profile = input.bool(true, 'show Profile', inline = 'profile'), 
 args_profile_line = D.LineArgs.new(input.color(#787b869e, '', inline = 'profile'), line.style_solid, 3, xloc.bar_time), 
 show_background = input.bool(true, 'with background', inline = 'profile'), 
 args_profile_bg = D.BoxArgs.new(#00000000, bg_color = input.color(#787b860f, '', inline = 'profile'), xloc = xloc.bar_time),
 
 extend = input.bool(true, 'extend profile', inline = 'extend')
 )

varip ProfileConfig argsi = args.deepcopy()
if barstate.isfirst
	argsi.args_poc_line.xloc := xloc.bar_index
	argsi.args_vah_line.xloc := xloc.bar_index
	argsi.args_val_line.xloc := xloc.bar_index
	argsi.args_poc_label.xloc := xloc.bar_index
	argsi.args_vah_label.xloc := xloc.bar_index
	argsi.args_val_label.xloc := xloc.bar_index
	argsi.args_profile_line.xloc := xloc.bar_index
	argsi.args_profile_bg.xloc := xloc.bar_index
 

var use_open_close_data_for_ranges_shorter_than_bars = input.int(4, 'max range to use open/close data', tooltip = 'if a range has lesser candles than this, open and close data will be included in the weight for a profile section. Body has a weight of 1.5, wicks 1 each, assuming there was more action due to accumulation.')

var g_use_cases = 'DEMO'
var use_case = input.string('High Volume Candle + LTF Detail', 'Use Case', ['High Volume Candle + LTF Detail', 'High Volume Candle + Lookback Range', 'Current Candle Live', 'Current Range Live', 'Weekly Range', 'Weekly Range Live'], group = g_use_cases)
var use_case_LTF = str.contains(use_case, 'LTF')
var use_case_lookback = str.contains(use_case, 'Lookback')
var use_case_live = str.contains(use_case, 'Candle Live')
var use_case_live_range = use_case == 'Current Range Live'
var use_case_weekly = use_case == 'Weekly Range'
var use_case_weekly_live = use_case == 'Weekly Range Live'

var value_select = input.string('volume', 'Profile value', ['volume', 'time'], group = g_use_cases)
var value_is_volume = value_select == 'volume'
value = value_is_volume ? volume : time_close - time


var is_above_1h = timeframe.in_seconds() > timeframe.in_seconds('60')
var is_above_1h_label = label.new(chart.point.now(na), 'Chart timeframe > 1h\nprofile data incomplete', color = color.red, xloc = xloc.bar_time)



/////////////////////////////////////////////////////////////////////////////////////////////////////
// 						USE CASE (profile single high volume candle with ltf data)
/////////////////////////////////////////////////////////////////////////////////////////////////////

//@description returns a lower timeframe to get a reasonable amount of data for volume spread analysis (>1M -> 1D) / (>1W -> 1H) / (>5m -> 10S) / (else 1S)
//@param detail_lvl select a value between 0-4 to decrease the returned LTF. This will lead to improved detail of generated profiles, but also require significant more computing power and slow down your script. (default: 1)
//@param allow_seconds if true this will use second based timeframes. This will significantly increase detail and script runtime in <=1h timeframes (only for premium users)
export get_ltf(simple int detail_lvl = 1, simple bool allow_seconds = false) =>
	tf_min = timeframe.in_seconds() / 60

	// detail lvl 0 (divide lvl4 by 10 => x10 the LTF timeframe)
	// tf_min >= 43200 minutes == >= 30 days  => LTF =>  10D => candles:   3 ( 1M) -  35 (12M)
	// tf_min >= 10080 minutes == >= 7 days   => LTF => 600m => candles:  16 ( 1W) -  67 ( 1M)
	// tf_min >=  1440 minutes == >= 12 hours => LTF => 150m => candles:   4 (12h) -  67 ( 7D)
	// tf_min >=    60 minutes == >=  1 hour  => LTF =>  10m => candles:   6 ( 1h) -  72 (12h)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>   1m => candles:   1 ( 6m) -   6 ( 1h) (REGULAR)
	// tf_min >=     6 minutes == >=  6 mins  => LTF => 100S => candles:   3 ( 6m) -  36 ( 1h) (PREMIUM)
	// tf_min <      6 minutes == <=  6 mins  => LTF =>  10S => candles:   1 ( 1s) -  36 ( 6m) (PREMIUM)

	// detail lvl 1 (divide lvl4 by 5 => x5 the LTF timeframe)
	// tf_min >= 43200 minutes == >= 30 days  => LTF =>   5D => candles:  6 ( 1M) -  14 (12M)
	// tf_min >= 10080 minutes == >= 7 days   => LTF => 300m => candles: 31 ( 1W) -  64 ( 1M)
	// tf_min >=  1440 minutes == >= 12 hours => LTF =>  75m => candles:  9 (12h) -  64 ( 7D)
	// tf_min >=    60 minutes == >=  1 hour  => LTF =>   5m => candles: 12 ( 1h) -  48 (12h)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>   5m => candles:  1 ( 6m) -   4 ( 1h) (REGULAR)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>  50S => candles:  7 ( 6m) -  24 ( 1h) (PREMIUM)
	// tf_min <      6 minutes == <=  6 mins  => LTF =>   5S => candles:  1 ( 1s) -  24 ( 6m) (PREMIUM)

	// detail lvl 2 (divide lvl4 by 3 => tripple the LTF timeframe)
	// tf_min >= 43200 minutes == >= 30 days  => LTF =>   3D => candles: 10 ( 1M) - 118 (12M)
	// tf_min >= 10080 minutes == >= 7 days   => LTF => 180m => candles: 56 ( 1W) - 324 ( 1M)
	// tf_min >=  1440 minutes == >= 12 hours => LTF =>  45m => candles: 16 (12h) - 324 ( 7D)
	// tf_min >=    60 minutes == >=  1 hour  => LTF =>   3m => candles: 20 ( 1h) - 240 (12h)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>   3m => candles:  2 ( 6m) -  20 ( 1h) (REGULAR)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>  30S => candles: 12 ( 6m) - 120 ( 1h) (PREMIUM)
	// tf_min <      6 minutes == <=  6 mins  => LTF =>   3S => candles:  1 ( 1s) - 120 ( 6m) (PREMIUM)

	// detail lvl 3 (divide lvl4 by 2 => double the LTF timeframe)
	// tf_min >= 43200 minutes == >= 30 days  => LTF =>   2D => candles: 15 ( 1M) - 179 (12M)
	// tf_min >= 10080 minutes == >= 7 days   => LTF => 120m => candles: 84 ( 1W) - 336 ( 1M)
	// tf_min >=  1440 minutes == >= 12 hours => LTF =>  30m => candles: 24 (12h) - 336 ( 7D)
	// tf_min >=    60 minutes == >=  1 hour  => LTF =>   2m => candles: 30 ( 1h) - 360 (12h)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>   2m => candles:  3 ( 6m) -  30 ( 1h) (REGULAR)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>  20S => candles: 18 ( 6m) - 180 ( 1h) (PREMIUM)
	// tf_min <      6 minutes == <=  6 mins  => LTF =>   2S => candles:  1 ( 1s) - 180 ( 6m) (PREMIUM)

	// detail lvl 4
	// tf_min >= 43200 minutes == >= 30 days  => LTF =>  1D => candles:  30 ( 1M) - 356 (12M)
	// tf_min >= 10080 minutes == >= 7 days   => LTF => 60m => candles: 168 ( 1W) - 672 ( 1M)
	// tf_min >=  1440 minutes == >= 12 hours => LTF => 15m => candles:  48 (12h) - 672 ( 7D)
	// tf_min >=    60 minutes == >=  1 hour  => LTF =>  1m => candles:  60 ( 1h) - 720 (12h)
	// tf_min >=     6 minutes == >=  6 mins  => LTF =>  1m => candles:   6 ( 6m) -  60 ( 1h) (REGULAR)
	// tf_min >=     6 minutes == >=  6 mins  => LTF => 10S => candles:  36 ( 6m) - 360 ( 1h) (PREMIUM)
	// tf_min <      6 minutes == <=  6 mins  => LTF =>  1S => candles:   1 ( 1s) - 360 ( 6m) (PREMIUM)

	ltf = switch detail_lvl
		4 => tf_min >= 43200 ?  '1D' : tf_min >= 10080 ?  '60' : tf_min >= 1440 ?  '15' : tf_min >= 60 ?  '1' :                                           					   tf_min >= 1 ?  '10S' :  '1S'
		3 => tf_min >= 43200 ?  '2D' : tf_min >= 10080 ? '120' : tf_min >= 1440 ?  '30' : tf_min >= 60 ?  '2' : 					 tf_min >=  6 or not allow_seconds ? '1' : tf_min >= 1 ?  '20S' :  '2S'
		2 => tf_min >= 43200 ?  '3D' : tf_min >= 10080 ? '180' : tf_min >= 1440 ?  '45' : tf_min >= 60 ?  '3' : tf_min >= 30 ? '2' : tf_min >=  6 or not allow_seconds ? '1' : tf_min >= 1 ?  '30S' :  '3S'
		1 => tf_min >= 43200 ?  '5D' : tf_min >= 10080 ? '300' : tf_min >= 1440 ?  '75' : tf_min >= 60 ?  '5' : tf_min >= 30 ? '3' : tf_min >= 10 or not allow_seconds ? '2' : tf_min >= 1 ?  '30S' :  '5S'
		=>   tf_min >= 43200 ? '10D' : tf_min >= 10080 ? '600' : tf_min >= 1440 ? '150' : tf_min >= 60 ? '10' : tf_min >= 30 ? '5' : tf_min >= 15 or not allow_seconds ? '5' : tf_min >= 5 ?    '1' : '30S'

var int detail_lvl = input.int(0, 'detail lvl', [0,1,2,3,4], group = g_use_cases)
var ltf = get_ltf(detail_lvl)
var tf_min = timeframe.in_seconds() / 60
[ltf_opens, ltf_highs, ltf_lows, ltf_closes, ltf_values] = request.security_lower_tf(syminfo.tickerid, ltf, [open, high, low, close, value])

var ltf_label = label.new(time, 0, '', xloc.bar_time, color = #938616, style = label.style_label_left, size = size.normal)
var max_ltf_bars = 0
if max_ltf_bars < ltf_highs.size()// every time we get more ltf bars, store the max ltf bar count
	max_ltf_bars := ltf_highs.size()
ltf_label.set_text(str.format('res: {0}min + detail_lvl: {1}\n-> ltf: {2} -> max {3} ltf candles\ncurrent bar has {4} ltf candles',tf_min, detail_lvl, ltf, max_ltf_bars, ltf_highs.size()))
ltf_label.set_xy(time, high)

var volume_threshold_len = input.int(50, 'High volume candle - SMA len', inline = 'volume_threshold', group = g_use_cases)
var volume_threshold_mult = input.float(3, 'x', minval = 1, step =0.1, inline = 'volume_threshold', group = g_use_cases)
var Profile obj_prev = na
var Profile obj = na

volume_sma = ta.sma(volume, volume_threshold_len)
var tf_ms = timeframe.in_seconds() * 1000

if use_case_LTF // HIGH VOLUME CANDLE
	if volume > volume_sma * volume_threshold_mult

		if ltf_values.size() == 0
			label.new(bar_index, close, "ltf data empty\ncan't plot profile", yloc = yloc.abovebar, color = color.red, textcolor = color.white, size = size.normal)
		else
			// just keep last 2
			if not na(obj_prev)
				obj_prev.delete()

			if not na(obj)
				obj_prev := obj

			obj := create_profile(ltf_opens, ltf_highs, ltf_lows, ltf_closes, ltf_values, resolution, vah_pc, val_pc, bar_index, init_calculated = true, use_open_close_data_for_ranges_shorter_than_bars = use_open_close_data_for_ranges_shorter_than_bars)
			obj.draw(argsi, bar_index, bar_index + 20)

			if not na(obj.plot_profile_bg)
				ltf_label.set_point(obj.plot_profile_bg.left_top)

	// obj.draw()


/////////////////////////////////////////////////////////////////////////////////////////////////////
// 							USE CASE (profile timeframe from chart history candles)
/////////////////////////////////////////////////////////////////////////////////////////////////////


_history(src, int amount, int offset = 0, int max_buffer_len = 250, capture_when = true, reset = false, allow_na_in_buffer = true) =>
	var buffer = array.from(src) // prevents having to define array type with array.new
	max_amount = ta.max(amount+offset)
	buffer_len = math.min(max_amount, max_buffer_len)

	if na(src) and not allow_na_in_buffer
		if buffer.size() == 1
			if na(buffer.first())
				buffer.clear() // prevent na in buffer

	if not na(src) or allow_na_in_buffer

		if reset
			buffer.clear()

		if capture_when
			if not barstate.isfirst
				buffer.unshift(src)

			if buffer.size() > buffer_len // prevent memory exceeded
				buffer.pop()

		// return
		if buffer.size() > 0 and amount > 0
			start_idx = math.min(buffer.size() - 1 , math.abs(offset))
			end_idx   = math.min(buffer.size()     , start_idx + math.abs(amount))

			buffer.slice(start_idx, end_idx)
		else 
			buffer

//@function allows fetching an array of values from the history series with offset from current candle
export history(int src, int amount, int offset = 0, int max_buffer_len = 100, bool capture_when = true, bool reset = false) => _history(src, amount, offset, max_buffer_len, capture_when, reset)
//@function allows fetching an array of values from the history series with offset from current candle
export history(float src, int amount, int offset = 0, int max_buffer_len = 100, bool capture_when = true, bool reset = false) => _history(src, amount, offset, max_buffer_len, capture_when, reset)


// direct source previous candles
var history_len = input.int(20, 'Range Candles', inline = 'range')
var history_offset = input.int(2, 'Range Offset', inline = 'range')
opens = history(open, history_len, history_offset)
highs = history(high, history_len, history_offset)
lows = history(low, history_len, history_offset)
closes = history(close, history_len, history_offset)
values = history(value, history_len, history_offset)

var Profile obj2_prev = na
var Profile obj2 = na
var line range2_line_prev = na
var line range2_line = na
if use_case_lookback
	if volume > volume_sma * volume_threshold_mult // HIGH VOLUME CANDLE

		// just keep the last 2 profiles
		if not na(obj2)
			if not na(obj2_prev)
				obj2_prev.delete() 
				range2_line_prev.delete()
			obj2_prev := obj2			
			range2_line_prev := range2_line
			
		
		left  = bar_index - history_offset - values.size() // width should be == history_len but could be shorter when lesser candles are available
		right = bar_index - history_offset

		obj2 := create_profile(opens[history_offset], highs[history_offset], lows[history_offset], closes[history_offset], values[history_offset], resolution, vah_pc, val_pc, tickid, init_calculated = true, use_open_close_data_for_ranges_shorter_than_bars = use_open_close_data_for_ranges_shorter_than_bars )
		obj2.draw(argsi, left, right)
		
		range2_line := line.new(left, obj2.l, right, obj2.l, color = color.gray, width = 2)
		


/////////////////////////////////////////////////////////////////////////////////////////////////////
// 							USE CASE (profile timeframe from chart history candles)
/////////////////////////////////////////////////////////////////////////////////////////////////////

varip Profile obj3 = na
var lft_data_always_present_in_replay_label = label.new(chart.point.now(na), 'TV returns complete LTF data in replay\n=> shows final bar profile from the start', color = color.red, style = label.style_label_center)
if use_case_live
	if barstate.islastconfirmedhistory
		lft_data_always_present_in_replay_label.set_xy(bar_index, high + ta.tr / 10)

	if barstate.isfirst		
		obj3 := create_profile(ltf_opens, ltf_highs, ltf_lows, ltf_closes, ltf_values, resolution, vah_pc, val_pc, bar_index, init_calculated = false, use_open_close_data_for_ranges_shorter_than_bars = use_open_close_data_for_ranges_shorter_than_bars)

	if barstate.islast or barstate.islastconfirmedhistory
		// GOOD EXAMPLE FOR HIGH PERFORMANT LIVE PROCESSING AND DRAWING (init everything once, then just update)
		obj3.update(ltf_opens, ltf_highs, ltf_lows, ltf_closes, ltf_values)
		obj3.draw(argsi, bar_index, bar_index + 20, extend_only = false)


varip Profile obj4 = na
var line range4_line = line.new(na, na, na, na, color = color.gray, width = 2)
if use_case_live_range
	if barstate.isfirst
		obj4 := create_profile(opens, highs, lows, closes, values, resolution, vah_pc, val_pc, bar_index, init_calculated = false, use_open_close_data_for_ranges_shorter_than_bars = use_open_close_data_for_ranges_shorter_than_bars).draw(argsi, bar_index, bar_index + 1)

	if barstate.islast
		range_size = nz(values.size(), 0)
		obj4.update(opens, highs, lows, closes, values)
		
		offset = history_offset + range_size - 1 // offset goes to last candle of range, then add one less than included in range
		left   = bar_index[offset]
		right  = bar_index[history_offset]

		obj4.draw(argsi, left, right, extend_only = false)
		range4_line.set_xy1(left , obj4.l)
		range4_line.set_xy2(right, obj4.l)


/////////////////////////////////////////////////////////////////////////////////////////////////////
// 							USE CASE (weekly profile)
/////////////////////////////////////////////////////////////////////////////////////////////////////

[open_1h, high_1h, low_1h, close_1h, value_1h, confirmed_1h] = request.security(syminfo.tickerid, '60', [open, high, low, close, value, barstate.isconfirmed])
next_period = timeframe.change('60') and not na(high_1h)
next_week   = timeframe.change('1W')
plotshape(next_period, 'next period', shape.circle, location.bottom, color.yellow)
plotshape(next_week	 , 'next week'  , shape.circle, location.top, color.orange)

week_bars = nz(ta.barssince(next_week) + 1, bar_index)
period_bars = nz(ta.barssince(next_period) + 1, bar_index)
plot(week_bars, 'week_bars', display = display.data_window)
plot(period_bars, 'period_bars', display = display.data_window)

opens_1h = history(open_1h, 7*24, max_buffer_len = 7*24, capture_when=next_period, reset = next_week)
closes_1h = history(close_1h, 7*24, max_buffer_len = 7*24, capture_when=next_period, reset = next_week)
highs_1h = history(high_1h, 7*24, max_buffer_len = 7*24, capture_when=next_period, reset = next_week)
lows_1h = history(low_1h, 7*24, max_buffer_len = 7*24, capture_when=next_period, reset = next_week)
values_1h = history(value_1h, 7*24, max_buffer_len = 7*24, capture_when=next_period, reset = next_week)

var int max_buffer_len = timeframe.in_seconds('1W') / timeframe.in_seconds()
opens_live = history(open, week_bars, 0, max_buffer_len, reset = next_week)
highs_live = history(high, week_bars, 0, max_buffer_len, reset = next_week)
lows_live = history(low, week_bars, 0, max_buffer_len, reset = next_week)
closes_live = history(close, week_bars, 0, max_buffer_len, reset = next_week)
values_live = history(value, week_bars, 0, max_buffer_len, reset = next_week)

var float[] prev_opens_1h = array.new<float>(0)
var float[] prev_highs_1h = array.new<float>(0)
var float[] prev_lows_1h = array.new<float>(0)
var float[] prev_closes_1h = array.new<float>(0)
var float[] prev_values_1h = array.new<float>(0)

var Profile last_week_profile = na
if use_case_weekly // only plot last weeks profile when new week begins
	if next_week	
		prev_week_time = time('1W',  1)
		curr_week_time = time('1W')
		// next_week_time = time_close('1W')		

		last_week_profile := create_profile(prev_opens_1h, prev_highs_1h, prev_lows_1h, prev_closes_1h, prev_values_1h, resolution, vah_pc, val_pc, bar_index, init_calculated = true, use_open_close_data_for_ranges_shorter_than_bars = na)
		
		if not barstate.isfirst and not na(last_week_profile)
			last_week_profile.draw(args, prev_week_time, curr_week_time, extend_only = false)

			// range line
			line.new(prev_week_time, last_week_profile.l, curr_week_time, last_week_profile.l, xloc.bar_time, color = color.new(color.gray, 50), width = 2)

			if is_above_1h
				is_above_1h_label.set_xy(int(math.avg(prev_week_time, curr_week_time)), last_week_profile.h)

var Profile curr_week_profile = na
var line curr_range_line = na
if use_case_weekly_live
	curr_week_time = time('1W')
	next_week_time = time_close('1W')
	var one_week_ms = 604800000 // 7 * 24 * 60 * 60 * 1000 // this is a fallback, some weeks close earlier, not all on sunday
	if na(next_week_time) or next_week_time < curr_week_time
		next_week_time := curr_week_time + one_week_ms
		
	if next_week and barstate.islast or barstate.islastconfirmedhistory[1]
		curr_week_profile := create_profile(opens_live, highs_live, lows_live, closes_live, values_live, resolution, vah_pc, val_pc, bar_index, init_calculated = true, use_open_close_data_for_ranges_shorter_than_bars = na)
		curr_range_line := line.new(curr_week_time, curr_week_profile.l, next_week_time, curr_week_profile.l, xloc.bar_time, color = color.new(color.gray, 50), width = 2)
		
	if not na(curr_week_profile) and (time_close == next_week_time or barstate.islast)
		curr_week_profile.update(opens_live, highs_live, lows_live, closes_live, values_live)
		curr_week_profile.draw(args, curr_week_time, next_week_time, extend_only = false)

		curr_range_line.set_xy1(curr_week_time, curr_week_profile.l)
		curr_range_line.set_xy2(next_week_time, curr_week_profile.l)

		if is_above_1h
			is_above_1h_label.set_xy(int(math.avg(curr_week_time, next_week_time)), curr_week_profile.h)


prev_opens_1h := opens_1h.copy()
prev_closes_1h := closes_1h.copy()
prev_highs_1h := highs_1h.copy()
prev_lows_1h := lows_1h.copy()
prev_values_1h := values_1h.copy()

